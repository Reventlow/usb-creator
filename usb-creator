# RESOLVED_ALGO is sha256 unless a resolver overrides it (EndeavourOS
# publishes sha512 sums). RESOLVED_RAW=1 marks images that are raw disk
# images rather than ISO9660 (the BSD USB installers) so the "does not
# look like an ISO" prompt is not raised for them.
RESOLVED_URL="" RESOLVED_FILE="" RESOLVED_HASH="" RESOLVED_ALGO="sha256"
RESOLVED_RAW=0

# Extract "SHA256 (filename) = hash" style (BSD-format) checksums, as
# published by FreeBSD, OpenBSD and Fedora.
bsd_checksum_for() {
    local sums="$1" file="$2"
    awk -v f="$file" \
        '$1 == "SHA256" && $2 == "(" f ")" { print tolower($4); exit }' <<<"$sums"
}

# Extract "<hash>  filename" style checksum for a given filename.
# Accepts the common variants: "hash filename", "hash *filename".
# CRLF line endings are stripped so a served \r cannot break the match.
checksum_for() {
    local sums="$1" file="$2"
    awk -v f="$file" '
        { sub(/\r$/, ""); fn = $2; sub(/^\*/, "", fn) }
        fn == f { print tolower($1); exit }
    ' <<<"$sums"
}

# Shared Ubuntu LTS machinery; $1 is the awk regex picking the image out
# of the (signature-verified) SHA256SUMS.
resolve_ubuntu_image() {
    local pattern="$1"
    local base="https://releases.ubuntu.com"
    local index versions ver sums
    index=$(fetch "$base/") || die "cannot reach $base"
    # Collect release directories like 24.04.2/ and keep LTS ones
    # (even major year, April release), newest last.
    versions=$(grep -oE 'href="[0-9]+\.[0-9]+(\.[0-9]+)?/"' <<<"$index" \
        | grep -oE '[0-9]+\.[0-9]+(\.[0-9]+)?' | sort -uV) || true
    ver=""
    local v major minor
    while IFS= read -r v; do
        major=${v%%.*}; minor=${v#*.}; minor=${minor%%.*}
        if (( major % 2 == 0 )) && [[ "$minor" == "04" ]]; then
            ver="$v"
        fi
    done <<<"$versions"
    [[ -n "$ver" ]] || die "could not determine latest Ubuntu LTS from $base"
    sums=$(fetch_signed_sums ubuntu "$base/$ver/SHA256SUMS" "$base/$ver/SHA256SUMS.gpg") \
        || die "cannot fetch Ubuntu SHA256SUMS"
    RESOLVED_FILE=$(awk -v p="$pattern" '{ fn=$2; sub(/^\*/,"",fn) }
        fn ~ p { print fn; exit }' <<<"$sums")
    [[ -n "$RESOLVED_FILE" ]] || die "no matching ISO found in Ubuntu $ver checksums"
    RESOLVED_URL="$base/$ver/$RESOLVED_FILE"
    RESOLVED_HASH=$(checksum_for "$sums" "$RESOLVED_FILE")
}

resolve_ubuntu()        { resolve_ubuntu_image '^ubuntu-.*-desktop-amd64\.iso$'; }
resolve_ubuntu_server() { resolve_ubuntu_image '^ubuntu-.*-live-server-amd64\.iso$'; }

resolve_kubuntu() {
    # Same cdimage infrastructure and CD-image signing key as Ubuntu. The
    # newest version directory can predate its release (no release/ files
    # yet), so walk versions newest-first until one has signed checksums.
    local base="https://cdimage.ubuntu.com/kubuntu/releases"
    local index ver sums
    index=$(fetch "$base/") || die "cannot reach $base"
    # shellcheck disable=SC2013  # version tokens contain no whitespace
    for ver in $(grep -oE 'href="[0-9]+\.[0-9]+(\.[0-9]+)?/"' <<<"$index" \
                 | grep -oE '[0-9]+\.[0-9]+(\.[0-9]+)?' | sort -urV); do
        # Cheap existence probe before the verifying fetch, to keep the
        # walk quiet across not-yet-released directories.
        fetch "$base/$ver/release/SHA256SUMS" >/dev/null 2>&1 || continue
        sums=$(fetch_signed_sums kubuntu "$base/$ver/release/SHA256SUMS" \
               "$base/$ver/release/SHA256SUMS.gpg") || continue
        RESOLVED_FILE=$(awk '{ fn=$2; sub(/^\*/,"",fn) }
            fn ~ /^kubuntu-.*-desktop-amd64\.iso$/ { print fn; exit }' <<<"$sums")
        [[ -n "$RESOLVED_FILE" ]] || continue
        RESOLVED_URL="$base/$ver/release/$RESOLVED_FILE"
        RESOLVED_HASH=$(checksum_for "$sums" "$RESOLVED_FILE")
        return 0
    done
    die "no released Kubuntu desktop ISO found"
}

resolve_debian() {
    # cdimage.debian.org first; the mirrors are safe fallbacks because the
    # SHA256SUMS signature is verified against the pinned Debian CD key —
    # a tampering mirror fails verification rather than being trusted.
    local base sums=""
    for base in "https://cdimage.debian.org/debian-cd/current/amd64/iso-cd" \
                "https://mirrors.dotsrc.org/debian-cd/current/amd64/iso-cd" \
                "https://ftp.halifax.rwth-aachen.de/debian-cd/current/amd64/iso-cd"; do
        sums=$(fetch_signed_sums debian "$base/SHA256SUMS" "$base/SHA256SUMS.sign") && break
        sums=""
    done
    [[ -n "$sums" ]] || die "cannot fetch Debian SHA256SUMS from any mirror"
    RESOLVED_FILE=$(awk '{ fn=$2; sub(/^\*/,"",fn) }
        fn ~ /^debian-[0-9.]+-amd64-netinst\.iso$/ { print fn; exit }' <<<"$sums")
    [[ -n "$RESOLVED_FILE" ]] || die "no netinst ISO found in Debian checksums"
    RESOLVED_URL="$base/$RESOLVED_FILE"
    RESOLVED_HASH=$(checksum_for "$sums" "$RESOLVED_FILE")
}

# Shared Fedora machinery. Fedora publishes machine-readable release data
# (used by Media Writer); the clearsigned CHECKSUM is verified against the
# first-party key bundle and must agree with releases.json.
# Args: variant, link substring, release-version regex (capture group 1).
resolve_fedora_variant() {
    local variant="$1" linksel="$2" relver_re="$3"
    local json
    json=$(fetch "https://fedoraproject.org/releases.json") \
        || die "cannot fetch Fedora releases.json"
    read -r RESOLVED_URL RESOLVED_HASH < <(jq -r --arg v "$variant" --arg s "$linksel" '
        [ .[]
          | select(.variant == $v and .arch == "x86_64")
          | select(.link | endswith(".iso") and contains($s))
          | select(.version | test("^[0-9]+$")) ]
        | max_by(.version | tonumber)
        | "\(.link) \(.sha256)"' <<<"$json") || true
    [[ -n "${RESOLVED_URL:-}" && "$RESOLVED_URL" != "null" ]] \
        || die "could not find a Fedora $variant ISO in releases.json"
    RESOLVED_FILE="${RESOLVED_URL##*/}"
    RESOLVED_HASH="${RESOLVED_HASH,,}"

    if gpg_active; then
        local relver dir checksum_url cfile signed_hash
        [[ "$RESOLVED_FILE" =~ $relver_re ]] \
            || die "unexpected Fedora ISO name '$RESOLVED_FILE'"
        relver="${BASH_REMATCH[1]}"
        # dl.fedoraproject.org is first-party (no mirror redirect).
        dir="${RESOLVED_URL%/*}"
        checksum_url="${dir/download.fedoraproject.org/dl.fedoraproject.org}/Fedora-${variant}-${relver}-x86_64-CHECKSUM"
        mktempf cfile
        fetch_to "$cfile" "$checksum_url" || die "cannot fetch the Fedora CHECKSUM file"
        gpg_verify_signed fedora "$cfile" \
            || die "GPG verification of the Fedora CHECKSUM FAILED — do not trust this source"
        signed_hash=$(bsd_checksum_for "$(cat "$cfile")" "$RESOLVED_FILE")
        [[ -n "$signed_hash" ]] || die "no entry for $RESOLVED_FILE in the Fedora CHECKSUM file"
        [[ "$signed_hash" == "$RESOLVED_HASH" ]] \
            || die "Fedora releases.json and the signed CHECKSUM disagree — refusing"
        info "Checksum signature verified (fedora signing key)"
    else
        warn "GPG signature of the fedora checksums NOT verified (gpg missing or --no-gpg)"
    fi
}

resolve_fedora() {
    resolve_fedora_variant Workstation "Workstation-Live" \
        '-([0-9]+-[0-9.]+)\.x86_64\.iso$'
}

resolve_fedora_server() {
    resolve_fedora_variant Server "Server-dvd" \
        'x86_64-([0-9]+-[0-9.]+)\.iso$'
}

resolve_almalinux() {
    # repo.almalinux.org is project infrastructure; the CHECKSUM file is
    # GPG-clearsigned by the per-major release key. The "latest" alias
    # tracks the newest point release; the minimal image is the sensible
    # server-install medium (the dvd is ~10 GB).
    local base="https://repo.almalinux.org/almalinux"
    local index major cfile sums
    index=$(fetch "$base/") || die "cannot reach $base"
    major=$(grep -oE 'href="[0-9]+/"' <<<"$index" | grep -oE '[0-9]+' | sort -un | tail -1)
    [[ -n "$major" ]] || die "could not determine the latest AlmaLinux major"
    RESOLVED_FILE="AlmaLinux-${major}-latest-x86_64-minimal.iso"
    RESOLVED_URL="$base/$major/isos/x86_64/$RESOLVED_FILE"
    if gpg_active; then
        mktempf cfile
        fetch_to "$cfile" "$base/$major/isos/x86_64/CHECKSUM" \
            || die "cannot fetch the AlmaLinux CHECKSUM file"
        gpg_verify_signed almalinux "$cfile" \
            || die "GPG verification of the AlmaLinux CHECKSUM FAILED — do not trust this source"
        info "Checksum signature verified (almalinux signing key)"
        sums=$(cat "$cfile")
    else
        warn "GPG signature of the almalinux checksums NOT verified (gpg missing or --no-gpg)"
        sums=$(fetch "$base/$major/isos/x86_64/CHECKSUM") \
            || die "cannot fetch the AlmaLinux CHECKSUM file"
    fi
    RESOLVED_HASH=$(bsd_checksum_for "$sums" "$RESOLVED_FILE")
}

resolve_arch() {
    local base="https://geo.mirror.pkgbuild.com/iso/latest"
    local sums
    sums=$(fetch "$base/sha256sums.txt") || die "cannot fetch Arch sha256sums.txt"
    RESOLVED_FILE=$(awk '{ fn=$2; sub(/^\*/,"",fn) }
        fn ~ /^archlinux-[0-9]{4}\.[0-9]{2}\.[0-9]{2}-x86_64\.iso$/ { print fn; exit }' \
        <<<"$sums")
    [[ -n "$RESOLVED_FILE" ]] || die "no dated ISO found in Arch checksums"
    RESOLVED_URL="$base/$RESOLVED_FILE"
    RESOLVED_HASH=$(checksum_for "$sums" "$RESOLVED_FILE")
    # Arch signs the ISO itself, not the checksum file.
    RESOLVED_ISO_SIG_URL="$RESOLVED_URL.sig"
}

resolve_manjaro() {
    # manjaro.org (first-party) embeds the current direct ISO links; the
    # checksum sits alongside the image on download.manjaro.org. A GPG
    # .sig is published too, but Manjaro's key documentation (their
    # GitLab) was not reliably reachable to pin a fingerprint against —
    # checksum + first-party TLS until that can be done properly.
    local page sums
    page=$(fetch "https://manjaro.org/products/download/x86") \
        || die "cannot reach manjaro.org"
    RESOLVED_URL=$(grep -oE 'https://download\.manjaro\.org/kde/[^"<> ]+\.iso' \
        <<<"$page" | head -1)
    [[ -n "$RESOLVED_URL" ]] || die "no KDE ISO link found on manjaro.org"
    RESOLVED_FILE="${RESOLVED_URL##*/}"
    sums=$(fetch "$RESOLVED_URL.sha256") || die "cannot fetch Manjaro checksum"
    RESOLVED_HASH=$(checksum_for "$sums" "$RESOLVED_FILE")
    [[ -n "$RESOLVED_HASH" ]] || RESOLVED_HASH=$(awk '{print tolower($1); exit}' <<<"$sums")
}

resolve_mint() {
    local base="https://mirrors.edge.kernel.org/linuxmint/stable"
    local index ver sums
    index=$(fetch "$base/") || die "cannot reach $base"
    ver=$(grep -oE 'href="[0-9]+(\.[0-9]+)*/"' <<<"$index" \
        | grep -oE '[0-9]+(\.[0-9]+)*' | sort -uV | tail -1)
    [[ -n "$ver" ]] || die "could not determine latest Mint version"
    sums=$(fetch_signed_sums mint "$base/$ver/sha256sum.txt" "$base/$ver/sha256sum.txt.gpg") \
        || die "cannot fetch Mint sha256sum.txt"
    RESOLVED_FILE="linuxmint-${ver}-cinnamon-64bit.iso"
    RESOLVED_URL="$base/$ver/$RESOLVED_FILE"
    RESOLVED_HASH=$(checksum_for "$sums" "$RESOLVED_FILE")
}

resolve_opensuse() {
    # Tumbleweed publishes a stable "Current" name with an adjacent .sha256,
    # itself signed by the openSUSE project key (.sha256.asc).
    local base="https://download.opensuse.org/tumbleweed/iso" sums
    RESOLVED_FILE="openSUSE-Tumbleweed-DVD-x86_64-Current.iso"
    RESOLVED_URL="$base/$RESOLVED_FILE"
    sums=$(fetch_signed_sums opensuse "$base/$RESOLVED_FILE.sha256" "$base/$RESOLVED_FILE.sha256.asc") \
        || die "cannot fetch openSUSE checksum"
    RESOLVED_HASH=$(awk '{print tolower($1); exit}' <<<"$sums")
}

resolve_alpine() {
    local base="https://dl-cdn.alpinelinux.org/alpine/latest-stable/releases/x86_64"
    local yaml
    yaml=$(fetch "$base/latest-releases.yaml") || die "cannot fetch Alpine release list"
    # Parse the YAML block for the "alpine-standard" flavor.
    read -r RESOLVED_FILE RESOLVED_HASH < <(awk '
        /flavor:/  { flavor = $2 }
        /file:/    { file = $2 }
        /sha256:/  { if (flavor == "alpine-standard" && file != "") {
                         print file, tolower($2); exit } }' <<<"$yaml") || true
    [[ -n "${RESOLVED_FILE:-}" ]] || die "no alpine-standard entry in release list"
    RESOLVED_URL="$base/$RESOLVED_FILE"
    # Alpine signs the ISO itself (detached .asc).
    RESOLVED_ISO_SIG_URL="$RESOLVED_URL.asc"
}

resolve_popos() {
    # System76 publishes a JSON build API per release/channel, but no
    # "latest" endpoint — probe plausible LTS versions, newest first.
    local year y ver json
    year=$(date +%Y)
    for (( y = year + 2 - year % 2; y >= 2020; y -= 2 )); do
        ver="$(( y - 2000 )).04"
        # 404s are expected while probing not-yet-released versions.
        json=$(fetch "https://api.pop-os.org/builds/$ver/intel" 2>/dev/null) || continue
        read -r RESOLVED_URL RESOLVED_HASH < <(jq -r '"\(.url) \(.sha_sum)"' <<<"$json") || true
        [[ -n "${RESOLVED_URL:-}" && "$RESOLVED_URL" != "null" ]] || continue
        RESOLVED_FILE="${RESOLVED_URL##*/}"
        RESOLVED_HASH="${RESOLVED_HASH,,}"
        return 0
    done
    die "could not find a Pop!_OS build via api.pop-os.org"
}

resolve_endeavouros() {
    # Trust anchor: endeavouros.com (first-party) supplies both the current
    # ISO filename and its sha512. Community mirrors only supply the bytes,
    # so a compromised mirror cannot serve a self-consistent malicious pair.
    local page hashes mirror
    page=$(fetch "https://endeavouros.com/latest-release/") \
        || page=$(fetch "https://endeavouros.com/") \
        || die "cannot reach endeavouros.com"
    # Filenames embed a codename and a date (EndeavourOS_Name-YYYY.MM.DD.iso);
    # pick the newest by the date part.
    RESOLVED_FILE=$(grep -oE 'EndeavourOS_[A-Za-z0-9_-]+-[0-9]{4}\.[0-9]{2}\.[0-9]{2}\.iso' <<<"$page" \
        | sort -u \
        | awk '{ d = $0; sub(/\.iso$/, "", d); n = split(d, a, "-"); print a[n], $0 }' \
        | sort -k1,1 | tail -1 | awk '{print $2}')
    [[ -n "$RESOLVED_FILE" ]] || die "no EndeavourOS ISO referenced on endeavouros.com"
    hashes=$(grep -oE '[0-9a-f]{128}' <<<"$page" | sort -u)
    [[ -n "$hashes" && $(wc -l <<<"$hashes") -eq 1 ]] \
        || die "could not identify a unique sha512 on endeavouros.com"
    RESOLVED_HASH="$hashes"
    RESOLVED_ALGO="sha512"
    # A mismatched (stale) mirror copy fails checksum verification, so any
    # healthy mirror is acceptable as a byte source.
    for mirror in "https://mirror.alpix.eu/endeavouros/iso" \
                  "https://mirror.moson.org/endeavouros/iso"; do
        if curl -fsIL --connect-timeout 15 -o /dev/null "$mirror/$RESOLVED_FILE"; then
            RESOLVED_URL="$mirror/$RESOLVED_FILE"
            # The .sig is detached over the ISO; the mirror serving it is
            # irrelevant because the signer key is pinned first-party.
            RESOLVED_ISO_SIG_URL="$RESOLVED_URL.sig"
            return 0
        fi
    done
    die "no EndeavourOS mirror currently serves $RESOLVED_FILE"
}

resolve_bluefin() {
    # Universal Blue sibling of Bazzite: stable alias plus an adjacent
    # GNU-format checksum on first-party infrastructure.
    local base="https://download.projectbluefin.io" sums
    RESOLVED_FILE="bluefin-stable-x86_64.iso"
    RESOLVED_URL="$base/$RESOLVED_FILE"
    sums=$(fetch "$base/$RESOLVED_FILE-CHECKSUM") || die "cannot fetch Bluefin checksum"
    RESOLVED_HASH=$(checksum_for "$sums" "$RESOLVED_FILE")
}

resolve_nyarch() {
    # Nyarch distributes via SourceForge and publishes no usable integrity
    # data (only SourceForge's own MD5, which is not collision-resistant),
    # so this joins the TLS-only "none" class — and here TLS terminates at
    # SourceForge's third-party mirror pool, the weakest trust story in
    # this registry. The tool says so loudly at every step.
    local json
    json=$(fetch "https://sourceforge.net/projects/nyarchlinux/best_release.json") \
        || die "cannot reach the Nyarch release API"
    RESOLVED_FILE=$(jq -r '.release.filename // empty' <<<"$json" | sed 's|^/||')
    [[ -n "$RESOLVED_FILE" ]] || die "no release file in the Nyarch release data"
    RESOLVED_URL="https://downloads.sourceforge.net/project/nyarchlinux/$RESOLVED_FILE"
    RESOLVED_ALGO="none"
}

resolve_bazzite() {
    # Stable alias for the KDE desktop image, with an adjacent checksum file.
    local base="https://download.bazzite.gg" sums
    RESOLVED_FILE="bazzite-stable-amd64.iso"
    RESOLVED_URL="$base/$RESOLVED_FILE"
    sums=$(fetch "$base/$RESOLVED_FILE-CHECKSUM") || die "cannot fetch Bazzite checksum"
    RESOLVED_HASH=$(checksum_for "$sums" "$RESOLVED_FILE")
}

resolve_cachyos() {
    # mirror.cachyos.org (first-party) hosts listings, checksums and the
    # detached ISO signature; the cdn77 endpoint (also cachyos.org) serves
    # the bytes. Release dirs are YYMMDD.
    local base="https://mirror.cachyos.org/ISO/desktop"
    local index ver sums
    index=$(fetch "$base/") || die "cannot reach $base"
    ver=$(grep -oE 'href="[0-9]{6}/"' <<<"$index" | grep -oE '[0-9]{6}' | sort -n | tail -1)
    [[ -n "$ver" ]] || die "could not determine latest CachyOS release"
    RESOLVED_FILE="cachyos-desktop-linux-${ver}.iso"
    sums=$(fetch "$base/$ver/$RESOLVED_FILE.sha256") || die "cannot fetch CachyOS checksum"
    RESOLVED_HASH=$(checksum_for "$sums" "$RESOLVED_FILE")
    RESOLVED_URL="https://cdn77.cachyos.org/ISO/desktop/$ver/$RESOLVED_FILE"
    RESOLVED_ISO_SIG_URL="$base/$ver/$RESOLVED_FILE.sig"
}

resolve_garuda() {
    # iso.builds.garudalinux.org is project infrastructure. latest.iso is
    # a stable alias; its .sha256 names the real versioned filename, which
    # becomes the cache name.
    local base="https://iso.builds.garudalinux.org/iso/latest/garuda/dr460nized"
    local sums
    sums=$(fetch "$base/latest.iso.sha256") || die "cannot fetch Garuda checksum"
    RESOLVED_HASH=$(awk '{print tolower($1); exit}' <<<"$sums")
    RESOLVED_FILE=$(awk '{fn = $2; sub(/^\*/, "", fn); print fn; exit}' <<<"$sums")
    [[ -n "$RESOLVED_FILE" ]] || die "Garuda checksum file names no ISO"
    RESOLVED_URL="$base/latest.iso"
}

resolve_tails() {
    # tails.net publishes machine-readable release data (used by Tails'
    # own upgrader). The USB image is raw (not ISO9660) and carries a
    # detached OpenPGP signature by the Tails signing key.
    local json
    json=$(fetch "https://tails.net/install/v2/Tails/amd64/stable/latest.json") \
        || die "cannot fetch the Tails release data"
    read -r RESOLVED_URL RESOLVED_HASH < <(jq -r '
        [.installations[0]."installation-paths"[]."target-files"[]
         | select(.url | endswith(".img"))][0]
        | ((.url // "") + " " + (.sha256 // ""))' <<<"$json") || true
    [[ -n "${RESOLVED_URL:-}" ]] || die "no USB image in the Tails release data"
    RESOLVED_FILE="${RESOLVED_URL##*/}"
    RESOLVED_HASH="${RESOLVED_HASH,,}"
    RESOLVED_RAW=1
    RESOLVED_ISO_SIG_URL="$RESOLVED_URL.sig"
}

resolve_qubes() {
    # ftp.qubes-os.org is project infrastructure. The ISO carries a
    # detached signature by the per-major-release signing key (itself
    # signed by the Qubes Master Signing Key); a new major release needs
    # a deliberate pin + key URL update here, same policy as Kali.
    local base="https://ftp.qubes-os.org/iso"
    local index digests
    index=$(fetch "$base/") || die "cannot reach $base"
    RESOLVED_FILE=$(grep -oE 'href="Qubes-R[0-9.]+-x86_64\.iso"' <<<"$index" \
        | grep -oE 'Qubes-R[0-9.]+-x86_64\.iso' | sort -uV | tail -1)
    [[ -n "$RESOLVED_FILE" ]] || die "no Qubes release ISO found"
    digests=$(fetch "$base/$RESOLVED_FILE.DIGESTS") || die "cannot fetch Qubes DIGESTS"
    # DIGESTS mixes md5/sha1/sha256/sha512 lines; keep only sha256-sized.
    RESOLVED_HASH=$(checksum_for "$(grep -E '^[0-9a-f]{64}[[:space:]]' <<<"$digests")" \
        "$RESOLVED_FILE")
    RESOLVED_URL="$base/$RESOLVED_FILE"
    RESOLVED_ISO_SIG_URL="$RESOLVED_URL.asc"
}

resolve_kali() {
    local base="https://cdimage.kali.org/current"
    local sums
    sums=$(fetch_signed_sums kali "$base/SHA256SUMS" "$base/SHA256SUMS.gpg") \
        || die "cannot fetch Kali SHA256SUMS"
    RESOLVED_FILE=$(awk '{ fn=$2; sub(/^\*/,"",fn) }
        fn ~ /^kali-linux-[0-9]{4}\.[0-9a-z]+-live-amd64\.iso$/ { print fn; exit }' <<<"$sums")
    [[ -n "$RESOLVED_FILE" ]] || die "no live ISO found in Kali checksums"
    RESOLVED_URL="$base/$RESOLVED_FILE"
    RESOLVED_HASH=$(checksum_for "$sums" "$RESOLVED_FILE")
}

resolve_omarchy() {
    # Omarchy publishes neither checksums nor signatures — only the ISO
    # itself over TLS. The homepage carries the current version's URL.
    local page
    page=$(fetch "https://omarchy.org") || die "cannot reach omarchy.org"
    RESOLVED_URL=$(grep -oE 'https://iso\.omarchy\.org/omarchy-[0-9]+\.[0-9]+\.[0-9]+\.iso' \
        <<<"$page" | head -1)
    [[ -n "$RESOLVED_URL" ]] || die "no ISO link found on omarchy.org"
    RESOLVED_FILE="${RESOLVED_URL##*/}"
    RESOLVED_ALGO="none"
}

resolve_zimaos() {
    # GitHub is ZimaOS's release channel. The expected hash is GitHub's
    # per-asset sha256 digest from the releases API — IceWhale's own
    # checksum files cover only the ZimaCube .img variants, not this ISO,
    # so the API digest (same trust anchor as the release itself) is the
    # authoritative integrity statement available.
    local json
    json=$(fetch "https://api.github.com/repos/IceWhaleTech/ZimaOS/releases/latest") \
        || die "cannot reach the ZimaOS releases API"
    read -r RESOLVED_URL RESOLVED_HASH < <(jq -r '
        [.assets[] | select(.name | test("^zimaos-x86_64-.*_installer\\.iso$"))][0]
        | ((.browser_download_url // "") + " "
           + ((.digest // "") | sub("^sha256:"; "")))' <<<"$json") || true
    [[ -n "${RESOLVED_URL:-}" ]] || die "no installer ISO in the latest ZimaOS release"
    RESOLVED_FILE="${RESOLVED_URL##*/}"
    RESOLVED_HASH="${RESOLVED_HASH,,}"
}

resolve_freebsd() {
    # download.freebsd.org is project infrastructure. The USB artifact is
    # the raw memstick image. The newest version directory can hold only
    # pre-release builds, so walk versions newest-first until one carries
    # a -RELEASE- checksum file.
    local base="https://download.freebsd.org/releases/amd64/amd64/ISO-IMAGES"
    local index ver sums
    index=$(fetch "$base/") || die "cannot reach $base"
    # shellcheck disable=SC2013  # version tokens contain no whitespace
    for ver in $(grep -oE 'href="[0-9]+\.[0-9]+/"' <<<"$index" \
                 | grep -oE '[0-9]+\.[0-9]+' | sort -urV); do
        sums=$(fetch "$base/$ver/CHECKSUM.SHA256-FreeBSD-${ver}-RELEASE-amd64" 2>/dev/null) \
            || continue
        RESOLVED_FILE="FreeBSD-${ver}-RELEASE-amd64-memstick.img"
        RESOLVED_HASH=$(bsd_checksum_for "$sums" "$RESOLVED_FILE")
        [[ -n "$RESOLVED_HASH" ]] || continue
        RESOLVED_URL="$base/$ver/$RESOLVED_FILE"
        RESOLVED_RAW=1
        return 0
    done
    die "no FreeBSD RELEASE memstick image found"
}

resolve_openbsd() {
    # cdn.openbsd.org is project infrastructure; installXX.img is the raw
    # USB installer. OpenBSD signs SHA256 with signify (not GPG), whose
    # per-release keys this tool does not pin — the checksum is trusted
    # via first-party TLS, like the other checksum-only distros.
    local base="https://cdn.openbsd.org/pub/OpenBSD"
    local index ver sums
    index=$(fetch "$base/") || die "cannot reach $base"
    ver=$(grep -oE 'href="[0-9]+\.[0-9]+/"' <<<"$index" \
        | grep -oE '[0-9]+\.[0-9]+' | sort -uV | tail -1)
    [[ -n "$ver" ]] || die "could not determine latest OpenBSD release"
    RESOLVED_FILE="install${ver/./}.img"
    sums=$(fetch "$base/$ver/amd64/SHA256") || die "cannot fetch OpenBSD SHA256"
    RESOLVED_HASH=$(bsd_checksum_for "$sums" "$RESOLVED_FILE")
    RESOLVED_URL="$base/$ver/amd64/$RESOLVED_FILE"
    RESOLVED_RAW=1
}

resolve_netbootxyz() {
    local base="https://boot.netboot.xyz/ipxe"
    local sums
    RESOLVED_FILE="netboot.xyz.iso"
    RESOLVED_URL="$base/$RESOLVED_FILE"
    sums=$(fetch "$base/netboot.xyz-sha256-checksums.txt") \
        || die "cannot fetch netboot.xyz checksums"
    RESOLVED_HASH=$(awk '/netboot\.xyz\.iso$/ {print tolower($1); exit}' <<<"$sums")
}

resolve_distro() {
    local id="$1"
    declare -F "resolve_${id//-/_}" >/dev/null \
        || die "unknown distro '$id' (see: $SCRIPT_NAME distros)"
    RESOLVED_URL="" RESOLVED_FILE="" RESOLVED_HASH="" RESOLVED_ALGO="sha256"
    RESOLVED_ISO_SIG_URL="" RESOLVED_GPG_ID="$id" RESOLVED_RAW=0
    info "Resolving latest release for '$id'..."
    "resolve_${id//-/_}"
    if [[ "$RESOLVED_ALGO" == "none" ]]; then
        warn "$id publishes no checksums or signatures — download integrity rests on TLS alone"
        return 0
    fi
    local want=64
    [[ "$RESOLVED_ALGO" == "sha512" ]] && want=128
    [[ "$RESOLVED_HASH" =~ ^[0-9a-f]+$ && ${#RESOLVED_HASH} -eq $want ]] \
        || die "resolver for '$id' returned an invalid $RESOLVED_ALGO ('$RESOLVED_HASH')"
}

# ---------------------------------------------------------------------------
# Device handling
# ---------------------------------------------------------------------------

# List whole disks that look like USB sticks: TYPE=disk and (removable or
# USB transport). Prints tab-separated: path, bytes, model, transport.
list_usb_devices() {
    lsblk -J -b -o PATH,TYPE,RM,TRAN,SIZE,MODEL 2>/dev/null | jq -r '
        .blockdevices[]
        | select(.type == "disk")
        | select((.rm == true or .rm == "1" or .rm == 1) or .tran == "usb")
        | [.path, (.size|tostring), (.model // "-" | tostring), (.tran // "-")]
        | @tsv'
}

# Print every mountpoint found on the device or any of its descendants
# (partitions, LUKS mappings, LVM volumes...). One per line.
# Returns non-zero (with no output) when the mount table cannot be read —
# callers MUST treat that as fatal, never as "no mounts".
device_mounts() {
    local json
    json=$(lsblk -J -o MOUNTPOINTS --paths "$1") || return 1
    jq -r '
        [.blockdevices[] | recurse(.children[]?) | .mountpoints[]?]
        | map(select(. != null)) | .[]' <<<"$json"
}

# A mountpoint that makes a disk part of the running system. Writing to such
# a disk is refused unconditionally — --force does not override this.
is_critical_mount() {
    case "$1" in
        /|/boot|/boot/*|/efi|/efi/*|/home|/home/*|/usr|/usr/*|/var|/var/*|\
        /etc|/etc/*|/opt|/opt/*|/srv|/srv/*|/root|/root/*|/tmp|/tmp/*|\
        /nix|/nix/*|"[SWAP]") return 0 ;;
        *) return 1 ;;
    esac
}

# ZFS pool member disks carry no mountpoint that lsblk can see, so an
# imported pool's disks would otherwise look idle. Refuse them outright;
# --force does not override this either.
refuse_zfs_pool_member() {
    local dev="$1" member
    command -v zpool >/dev/null 2>&1 || return 0
    while IFS= read -r member; do
        [[ -n "$member" ]] || continue
        if [[ "$member" == "$dev" || "$member" =~ ^"$dev"p?[0-9]+$ ]]; then
            die "'$dev' is a member of an imported ZFS pool. Refusing."
        fi
    done < <(zpool list -vHLP 2>/dev/null | awk '$1 ~ /^\/dev\// {print $1}')
    return 0
}

# Validate the target device and unmount its partitions. Dies on anything
# that looks like a system disk.
prepare_device() {
    local dev="$1" mp mounts
    [[ -e "$dev" ]] || die "device '$dev' does not exist"
    [[ -b "$dev" ]] || die "'$dev' is not a block device"

    local dtype rm tran
    read -r dtype rm tran < <(lsblk -dno TYPE,RM,TRAN "$dev" | awk '{print $1, $2, ($3 == "" ? "-" : $3)}')
    [[ "$dtype" == "disk" ]] \
        || die "'$dev' is a $dtype — pass the whole disk (e.g. /dev/sdb, not /dev/sdb1)"

    # If the mount table cannot be read we must not write anywhere.
    mounts=$(device_mounts "$dev") \
        || die "cannot enumerate mountpoints on '$dev' (lsblk failed) — refusing to write"

    # Refuse anything hosting the running system, always.
    if [[ -n "$mounts" ]]; then
        while IFS= read -r mp; do
            if is_critical_mount "$mp"; then
                die "'$dev' hosts '$mp' — this looks like a system disk. Refusing."
            fi
        done <<<"$mounts"
    fi
    refuse_zfs_pool_member "$dev"

    # Require a removable/USB disk unless the user forces it.
    if [[ "$rm" != "1" && "$tran" != "usb" ]] && (( ! OPT_FORCE )); then
        die "'$dev' is not removable and not on the USB bus (use --force to override)"
    fi

    # Unmount anything (auto-)mounted from the stick itself.
    if [[ -n "$mounts" ]]; then
        while IFS= read -r mp; do
            info "Unmounting $mp"
            run_root umount "$mp" || die "could not unmount $mp"
        done <<<"$mounts"
    fi
}

device_summary() {
    lsblk -dno PATH,SIZE,MODEL,TRAN,SERIAL "$1" 2>/dev/null | sed 's/  */  /g'
}

# ---------------------------------------------------------------------------
# Download & checksum
# ---------------------------------------------------------------------------

# Verify a file against an expected hash; algo is "sha256" or "sha512".
# algo "none" means the upstream publishes nothing to verify against.
verify_hash() {
    local file="$1" expected="${2,,}" algo="${3:-sha256}" actual
    if [[ "$algo" == "none" ]]; then
        warn "no upstream checksum exists for $(basename "$file") — integrity check skipped"
        return 0
    fi
    info "Verifying ${algo^^} of $(basename "$file")..."
    actual=$("${algo}sum" "$file" | awk '{print tolower($1)}')
    [[ "$actual" == "$expected" ]]
}

# Download RESOLVED_URL into the cache, verify against RESOLVED_HASH and
# print the final path on stdout. Reuses a cached copy when the hash matches.
download_iso() {
    local target="$CACHE_DIR/$RESOLVED_FILE" part rc=0
    mkdir -p "$CACHE_DIR"

    if [[ -f "$target" ]]; then
        if verify_hash "$target" "$RESOLVED_HASH" "$RESOLVED_ALGO"; then
            verify_iso_signature "$target"
            ok "Using cached ISO: $target"
            printf '%s\n' "$target"
            return 0
        fi
        warn "cached copy has a stale/bad checksum — downloading again"
        rm -f -- "$target"
    fi

    part="$target.part"
    info "Downloading $RESOLVED_URL"
    download_with_bar "$RESOLVED_URL" "$part" || rc=$?
    # curl exit 33 = server rejected the resume range; the .part file is most
    # likely already complete, so fall through to the checksum.
    if (( rc != 0 && rc != 33 )); then
        die "download failed (curl exit $rc); partial file kept for resume: $part"
    fi
    mv -- "$part" "$target"

    verify_hash "$target" "$RESOLVED_HASH" "$RESOLVED_ALGO" \
        || { rm -f -- "$target"; die "checksum mismatch — deleted corrupt download, please retry"; }
    [[ "$RESOLVED_ALGO" == "none" ]] || ok "Checksum verified ($RESOLVED_HASH)"
    verify_iso_signature "$target"
    printf '%s\n' "$target"
}

# Verify the distro's detached signature over the downloaded ISO, when one
# is published (arch, alpine, endeavouros). No-op for the others.
verify_iso_signature() {
    local target="$1" sig
    [[ -n "$RESOLVED_ISO_SIG_URL" ]] || return 0
    if ! gpg_active; then
        warn "GPG signature of the ISO NOT verified (gpg missing or --no-gpg)"
        return 0
    fi
    mktempf sig
    fetch_to "$sig" "$RESOLVED_ISO_SIG_URL" || die "cannot fetch the ISO signature"
    info "Verifying ISO signature..."
    gpg_verify_signed "$RESOLVED_GPG_ID" "$sig" "$target" \
        || die "GPG verification of the ISO FAILED — do not trust this image"
    ok "ISO signature verified ($RESOLVED_GPG_ID signing key)"
}

# Quick sanity check: ISO9660 images carry "CD001" at offset 32769.
looks_like_iso() {
    [[ "$(dd if="$1" bs=1 skip=32769 count=5 2>/dev/null)" == "CD001" ]]
}

# ---------------------------------------------------------------------------
# Writing
# ---------------------------------------------------------------------------

confirm_write() {
    local dev="$1" iso="$2"
    {
        printf '\n  %s──────────────────────────────────────────────────%s\n' "$C_ERR" "$C_OFF"
        printf '  %s%s⚠  ALL DATA ON THIS DEVICE WILL BE ERASED%s\n\n' "$C_ERR" "$C_BOLD" "$C_OFF"
        printf '     %s\n' "$(device_summary "$dev")"
        printf '     %simage:%s %s %s(%s)%s\n' "$C_DIM" "$C_OFF" "$(basename "$iso")" \
            "$C_DIM" "$(human_size "$(stat -c %s "$iso")")" "$C_OFF"
        printf '  %s──────────────────────────────────────────────────%s\n\n' "$C_ERR" "$C_OFF"
    } >&2

    (( OPT_YES )) && return 0
    local expected reply
    expected="$(basename "$dev")"
    read -r -p "  ${C_ACCENT}›${C_OFF} type the device name '$expected' to continue (anything else aborts): " reply \
        || die "aborted — no data was written"
    [[ "$reply" == "$expected" ]] || die "aborted — no data was written"
}

write_iso() {
    local iso="$1" dev="$2" iso_size
    iso_size=$(stat -c %s "$iso")

    # The device must be at least as large as the image.
    local dev_size
    dev_size=$(lsblk -dbno SIZE "$dev")
    (( dev_size >= iso_size )) \
        || die "device is too small: $(human_size "$dev_size") < $(human_size "$iso_size")"

    if (( ! RESOLVED_RAW )) && ! looks_like_iso "$iso"; then
        warn "'$(basename "$iso")' does not look like an ISO9660 image"
        if (( ! OPT_YES )); then
            local reply
            read -r -p "Write it anyway? [y/N] " reply || die "aborted"
            [[ "$reply" =~ ^[Yy] ]] || die "aborted"
        fi
    fi

    confirm_write "$dev" "$iso"

    # Take the sudo password prompt up front so it does not collide with
    # (or invisibly stall behind) the progress display.
    run_root true || die "cannot gain root privileges"

    info "Writing $(human_size "$iso_size") to $dev (this can take a while)..."
    run_root dd if="$iso" of="$dev" bs=4M conv=fsync oflag=direct status=progress \
        2> >(dd_progress_bar "$iso_size") \
        || die "dd failed — the device may be in an inconsistent state"
    # Give the bar a moment to print its final newline (bash does not let
    # us wait on the process substitution directly).
    sleep 0.2
    sync
    ok "Image written."

    if (( ! OPT_NO_VERIFY )); then
        info "Verifying written data (reading $(human_size "$iso_size") back)..."
        local expected actual
        expected=$(sha256sum "$iso" | awk '{print tolower($1)}')
        # iflag=direct bypasses the page cache so we test the real device.
        # dd's stderr feeds the progress bar; real errors pass through it.
        actual=$(run_root dd if="$dev" bs=4M iflag=direct,count_bytes count="$iso_size" \
                    status=progress 2> >(dd_progress_bar "$iso_size") \
                    | sha256sum | awk '{print tolower($1)}') \
            || die "could not read the device back for verification"
        [[ "$actual" == "$expected" ]] \
            || die "read-back verification FAILED — do not trust this stick"
        ok "Read-back verification passed."
    fi

    run_root eject "$dev" 2>/dev/null || true
    ok "Done. You can remove the USB stick."
}

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

cmd_list() {
    local rows
    rows=$(list_usb_devices)
    if [[ -z "$rows" ]]; then
        info "No removable/USB disks found. Plug in a stick and try again."
        return 0
    fi
    {
        printf 'DEVICE\tSIZE\tMODEL\tBUS\n'
        while IFS=$'\t' read -r path size model tran; do
            printf '%s\t%s\t%s\t%s\n' "$path" "$(human_size "$size")" "$model" "$tran"
        done <<<"$rows"
    } | if command -v column >/dev/null 2>&1; then column -t -s $'\t'; else cat; fi
}

cmd_distros() {
    local id cat c
    for cat in desktop server; do
        printf '\n%s%s%s\n\n' "$O_BOLD" "${cat^}" "$O_OFF"
        for id in "${DISTRO_IDS[@]}"; do
            c="${DISTRO_CATEGORY[$id]:-desktop}"
            [[ "$c" == "$cat" || "$c" == "both" ]] || continue
            printf '  %s%-14s%s %s%s%s\n' \
                "$O_ACCENT" "$id" "$O_OFF" "$O_MUT" "${DISTRO_DESC[$id]}" "$O_OFF"
        done
    done
    printf '\n%sUse a local image instead with: %s write --iso file.iso%s\n' \
        "$O_DIM" "$SCRIPT_NAME" "$O_OFF"
}

cmd_info() {
    [[ -n "$OPT_DISTRO" ]] || die "usage: $SCRIPT_NAME info <distro>"
    resolve_distro "$OPT_DISTRO"
    printf '%sdistro:%s   %s\n' "$O_DIM" "$O_OFF" "$OPT_DISTRO"
    printf '%sfile:%s     %s\n' "$O_DIM" "$O_OFF" "$RESOLVED_FILE"
    printf '%surl:%s      %s\n' "$O_DIM" "$O_OFF" "$RESOLVED_URL"
    if [[ "$RESOLVED_ALGO" == "none" ]]; then
        printf '%schecksum:%s NONE published by upstream (TLS-only download)\n' "$O_DIM" "$O_OFF"
    else
        printf '%s%-9s%s %s\n' "$O_DIM" "$RESOLVED_ALGO:" "$O_OFF" "$RESOLVED_HASH"
    fi
    local gpgline="no signatures published (checksum + TLS only)"
    [[ "$RESOLVED_ALGO" == "none" ]] && gpgline="none — upstream publishes no integrity data at all"
    if [[ -n "$RESOLVED_ISO_SIG_URL" ]]; then
        gpgline="detached ISO signature, key ${DISTRO_GPG_FPR[$OPT_DISTRO]:-}"
    elif [[ -n "${DISTRO_GPG_FPR[$OPT_DISTRO]:-}" ]]; then
        gpgline="signed checksums, key ${DISTRO_GPG_FPR[$OPT_DISTRO]}"
    elif [[ "$OPT_DISTRO" == fedora* ]]; then
        gpgline="signed checksums, keys from fedoraproject.org/fedora.gpg"
    fi
    printf '%sgpg:%s      %s\n' "$O_DIM" "$O_OFF" "$gpgline"
}

cmd_download() {
    [[ -n "$OPT_DISTRO" ]] || die "usage: $SCRIPT_NAME download <distro>"
    resolve_distro "$OPT_DISTRO"
    download_iso >/dev/null
}

# Self-update. Package-managed and git-checkout installs are handed to
# their proper update channel; only a standalone release install is
# replaced in place, after checksum verification of the download.
cmd_update() {
    local self dir
    self=$(readlink -f "$0")
    dir=$(dirname "$self")

    if command -v pacman >/dev/null 2>&1 && pacman -Qo "$self" >/dev/null 2>&1; then
        info "installed via pacman — update with: sudo pacman -Syu usb-creator"
        return 0
    fi
    if command -v dpkg >/dev/null 2>&1 && dpkg -S "$self" >/dev/null 2>&1; then
        info "installed via apt — update with: sudo apt update && sudo apt install usb-creator"
        return 0
    fi
    if command -v rpm >/dev/null 2>&1 && rpm -qf "$self" >/dev/null 2>&1; then
        info "installed via rpm — update with: sudo dnf upgrade usb-creator"
        return 0
    fi
    if git -C "$dir" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        info "running from a git checkout — update with: git -C $dir pull"
        return 0
    fi

    local base="https://github.com/Reventlow/usb-creator/releases/latest/download"
    local newfile sums expected newver
    mktempf newfile
    mktempf sums
    info "Fetching the latest release..."
    fetch_to "$newfile" "$base/usb-creator" || die "cannot download the latest release"
    fetch_to "$sums" "$base/SHA256SUMS" || die "cannot download the release checksums"
    expected=$(checksum_for "$(cat "$sums")" "usb-creator")
    [[ "$expected" =~ ^[0-9a-f]{64}$ ]] || die "release checksum file is malformed"
    verify_hash "$newfile" "$expected" sha256 \
        || die "checksum mismatch on the downloaded release — not installing it"
    bash -n "$newfile" 2>/dev/null || die "downloaded release does not parse — refusing"

    newver=$(sed -n 's/^VERSION="\(.*\)"/\1/p' "$newfile")
    [[ -n "$newver" ]] || die "cannot read the downloaded release's version"
    if [[ "$newver" == "$VERSION" ]]; then
        ok "Already up to date (v$VERSION)."
        return 0
    fi
    if [[ "$(printf '%s\n%s\n' "$newver" "$VERSION" | sort -V | tail -1)" == "$VERSION" ]]; then
        warn "latest release (v$newver) is older than this build (v$VERSION) — nothing to do"
        return 0
    fi

    if ! install -m755 "$newfile" "$self" 2>/dev/null; then
        info "elevated permissions needed to replace $self"
        run_root install -m755 "$newfile" "$self" || die "could not replace $self"
    fi
    ok "Updated v$VERSION → v$newver ($self)"
}

cmd_write() {
    local iso
    if [[ -n "$OPT_DISTRO" && -n "$OPT_ISO" ]]; then
        die "--distro and --iso are mutually exclusive"
    elif [[ -n "$OPT_DISTRO" ]]; then
        resolve_distro "$OPT_DISTRO"
        iso=$(download_iso)
    elif [[ -n "$OPT_ISO" ]]; then
        iso="$OPT_ISO"
        [[ -f "$iso" ]] || die "ISO not found: $iso"
    else
        die "specify an image: --distro <name> or --iso <file>"
    fi

    if [[ -z "$OPT_DEVICE" ]]; then
        if (( OPT_YES )); then
            die "--yes requires an explicit --device"
        fi
        OPT_DEVICE=$(pick_device)
    fi

    prepare_device "$OPT_DEVICE"
    write_iso "$iso" "$OPT_DEVICE"
}

# Interactive device picker; prints the chosen path on stdout.
pick_device() {
    local rows paths=() entries=()
    rows=$(list_usb_devices)
    [[ -n "$rows" ]] || die "no removable/USB disks found — plug one in and retry"
    while IFS=$'\t' read -r path size model tran; do
        paths+=("$path")
        entries+=("$path|$(human_size "$size")  $model ($tran)")
    done <<<"$rows"

    menu_pick "Which device should it be written to?" "${entries[@]}"
    printf '%s\n' "${paths[$MENU_INDEX]}"
}

# Interactive wizard: pick a source, pick a device, write.
cmd_interactive() {
    [[ -t 0 ]] || die "no terminal available — use explicit commands (see --help)"
    banner

    menu_pick "What kind of system?" \
        "desktop|graphical workstations and live systems" \
        "server|headless installs and home-server systems" \
        "local ISO|use an image file you already have"

    if (( MENU_INDEX == 2 )); then
        read -e -r -p "  ${C_ACCENT}›${C_OFF} path to image: " OPT_ISO </dev/tty \
            || die "aborted"
        [[ -n "$OPT_ISO" ]] || die "no path entered"
        # Expand a leading ~/ only; '~user/...' is passed through untouched.
        # shellcheck disable=SC2088  # comparing against a literal tilde is the point
        [[ "$OPT_ISO" == "~/"* ]] && OPT_ISO="$HOME/${OPT_ISO#\~/}"
    else
        local kind=desktop
        (( MENU_INDEX == 1 )) && kind=server
        local entries=() ids=() id cat
        for id in "${DISTRO_IDS[@]}"; do
            cat="${DISTRO_CATEGORY[$id]:-desktop}"
            [[ "$cat" == "$kind" || "$cat" == "both" ]] || continue
            ids+=("$id")
            entries+=("$id|${DISTRO_DESC[$id]}")
        done
        menu_pick "Which system?" "${entries[@]}"
        OPT_DISTRO="${ids[$MENU_INDEX]}"
    fi

    # Ask both questions up front — the (possibly long) download starts only
    # after the target device is chosen.
    OPT_DEVICE=$(pick_device)
    cmd_write
}

usage() {
    cat <<EOF
$SCRIPT_NAME v$VERSION — create bootable USB installers for Linux distros.

USAGE
    $SCRIPT_NAME                          interactive wizard
    $SCRIPT_NAME list                     list candidate USB devices
    $SCRIPT_NAME distros                  list supported distros
    $SCRIPT_NAME info <distro>            show resolved URL and checksum
    $SCRIPT_NAME download <distro>        download + verify ISO into the cache
    $SCRIPT_NAME write [options]          write an image to a USB device
    $SCRIPT_NAME update                   update this tool to the latest release

WRITE OPTIONS
    --distro <name>     download (or reuse cached) ISO for <name>
    --iso <file>        use a local image file instead
    --device <dev>      target whole-disk device, e.g. /dev/sdb
    --yes               no confirmation prompt (requires --device)
    --force             allow non-removable disks (system disks stay blocked)
    --no-verify         skip post-write read-back verification
    --no-gpg            skip GPG signature verification (checksums still checked)

OTHER
    -h, --help          this help
    -V, --version       print version

EXAMPLES
    $SCRIPT_NAME write --distro fedora --device /dev/sdb
    $SCRIPT_NAME write --iso ~/isos/custom.iso --device /dev/sdb --yes
    ISO cache: $CACHE_DIR
EOF
}

# ---------------------------------------------------------------------------
# Argument parsing / main
# ---------------------------------------------------------------------------

parse_args() {
    COMMAND=""
    while (($#)); do
        case "$1" in
            list|distros|write|update) COMMAND="$1" ;;
            --update) COMMAND="update" ;;
            info|download)
                COMMAND="$1"
                if [[ -n "${2:-}" && "${2:0:1}" != "-" ]]; then
                    OPT_DISTRO="$2"; shift
                fi
                ;;
            --distro)    OPT_DISTRO="${2:?--distro needs a value}"; shift ;;
            --iso)       OPT_ISO="${2:?--iso needs a value}"; shift ;;
            --device)    OPT_DEVICE="${2:?--device needs a value}"; shift ;;
            --yes|-y)    OPT_YES=1 ;;
            --force)     OPT_FORCE=1 ;;
            --no-verify) OPT_NO_VERIFY=1 ;;
            --no-gpg)    OPT_NO_GPG=1 ;;
            -h|--help)   usage; exit 0 ;;
            -V|--version) printf 'usb-creator %s\n' "$VERSION"; exit 0 ;;
            *) die "unknown argument '$1' (see --help)" ;;
        esac
        shift
    done
}

main() {
    require_deps
    parse_args "$@"
    # Options without a command must not fall into the wizard: pre-set
    # --device/--yes there could trigger a write with no confirmation.
    if [[ -z "${COMMAND:-}" ]] \
        && [[ -n "$OPT_DISTRO$OPT_ISO$OPT_DEVICE" || $((OPT_YES + OPT_FORCE + OPT_NO_VERIFY)) -gt 0 ]]; then
        die "options need a command — did you mean: $SCRIPT_NAME write ...? (see --help)"
    fi
    case "${COMMAND:-}" in
        list)     cmd_list ;;
        distros)  cmd_distros ;;
        info)     cmd_info ;;
        download) cmd_download ;;
        write)    cmd_write ;;
        update)   cmd_update ;;
        "")       cmd_interactive ;;
    esac
}

# Run only when executed, not when sourced (sourcing is used by tests).
if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
    main "$@"
fi
