#!/usr/bin/env bash
#
# usb-creator — create bootable USB installers for Linux distributions.
#
# A single-file shell tool that:
#   * lists safe candidate USB devices (whole removable disks only),
#   * resolves and downloads the latest ISO for a curated set of distros,
#   * verifies every download against the distro's official checksums and,
#     where the distro publishes them, GPG signatures with pinned keys,
#   * writes the image with dd and verifies the write by reading it back,
#   * refuses to touch any disk that backs a mounted system path.
#
# Usage:  usb-creator [command] [options]      (see: usb-creator --help)
# Deps :  bash >= 4, coreutils, util-linux (lsblk/findmnt), curl, jq, sudo
#         gnupg (optional, for signature verification)
#
# Author: Gorm Reventlow
# License: MIT
set -euo pipefail

VERSION="0.4.0"
SCRIPT_NAME="$(basename "$0")"
CACHE_DIR="${USB_CREATOR_CACHE:-${XDG_CACHE_HOME:-$HOME/.cache}/usb-creator}"

# Options (set by parse_args)
OPT_DEVICE=""            # target block device, e.g. /dev/sdb
OPT_ISO=""               # local ISO path (alternative to --distro)
OPT_DISTRO=""            # distro id from the registry below
OPT_YES=0                # skip interactive confirmation (scripting)
OPT_FORCE=0              # allow non-removable (but never system) disks
OPT_NO_VERIFY=0          # skip post-write read-back verification
OPT_NO_GPG=0             # skip GPG signature verification of downloads

# ---------------------------------------------------------------------------
# Output helpers
# ---------------------------------------------------------------------------

# Colors only when stderr is a terminal.
if [[ -t 2 ]]; then
    C_RED=$'\033[1;31m'; C_YEL=$'\033[1;33m'; C_GRN=$'\033[1;32m'
    C_BLU=$'\033[1;34m'; C_OFF=$'\033[0m'
else
    C_RED=""; C_YEL=""; C_GRN=""; C_BLU=""; C_OFF=""
fi

info()  { printf '%s\n' "${C_BLU}::${C_OFF} $*" >&2; }
ok()    { printf '%s\n' "${C_GRN}OK${C_OFF} $*" >&2; }
warn()  { printf '%s\n' "${C_YEL}warning:${C_OFF} $*" >&2; }
die()   { printf '%s\n' "${C_RED}error:${C_OFF} $*" >&2; exit 1; }

# Format a byte count for humans (e.g. 4013948928 -> 3.8G).
human_size() { numfmt --to=iec --format='%.1f' "$1" 2>/dev/null || printf '%s' "$1"; }

# Draw/refresh a single-line progress bar on stderr.
# Args: current_bytes total_bytes speed_string eta_string
draw_bar() {
    local cur=$1 total=$2 speed="$3" eta="$4" width=28 pct=0 filled i bar=""
    (( total > 0 )) && pct=$(( cur * 100 / total ))
    (( pct > 100 )) && pct=100
    filled=$(( pct * width / 100 ))
    for (( i = 0; i < width; i++ )); do
        if (( i < filled )); then bar+="█"; else bar+="░"; fi
    done
    printf '\r\033[K  %s %3d%%  %s / %s  %s  ETA %s ' \
        "$bar" "$pct" "$(human_size "$cur")" "$(human_size "$total")" \
        "$speed" "$eta" >&2
}

# Turn dd's status=progress stream (read from stdin) into a progress bar.
# Real dd error messages are passed through untouched; without a terminal
# the stream is forwarded as-is. Usage:
#   dd ... status=progress 2> >(dd_progress_bar TOTAL_BYTES)
dd_progress_bar() {
    local total=$1 chunk line cur speed eta eta_s elapsed start=$SECONDS
    if [[ ! -t 2 ]]; then
        cat >&2
        return 0
    fi
    draw_bar 0 "$total" "starting" "--:--"
    # Read dd's carriage-return-separated updates directly. No intermediate
    # command (tr & co) may sit in this path: its stdio buffering would hold
    # updates back for minutes and make the bar appear only near the end.
    while IFS= read -r -d $'\r' chunk || [[ -n "$chunk" ]]; do
        # A chunk can carry several newline-separated lines (dd's final
        # records in/out summary arrives that way).
        while IFS= read -r line; do
            [[ -n "$line" ]] || continue
            if [[ "$line" =~ ^([0-9]+)\ bytes ]]; then
                cur=${BASH_REMATCH[1]}
                speed="${line##*, }"
                elapsed=$(( SECONDS - start ))
                eta="--:--"
                if (( cur >= total )); then
                    eta="0:00"
                elif (( cur > 0 && elapsed > 0 )); then
                    eta_s=$(( (total - cur) * elapsed / cur ))
                    eta=$(printf '%d:%02d' $(( eta_s / 60 )) $(( eta_s % 60 )))
                fi
                draw_bar "$cur" "$total" "$speed" "$eta"
            elif [[ "$line" =~ records\ (in|out)$ ]]; then
                continue
            else
                printf '\n%s\n' "$line" >&2
            fi
        done <<<"$chunk"
    done
    printf '\n' >&2
}

# Download a URL to a file (resumable) with the same progress bar.
# Falls back to curl's own meter when there is no terminal or the server
# does not announce a content length.
download_with_bar() {
    local url="$1" out="$2" total cur prev speed eta eta_s delta rc=0 pid
    total=$(curl -fsIL --connect-timeout 15 "$url" 2>/dev/null \
        | awk 'tolower($1) == "content-length:" { len = $2 } END { gsub(/\r/, "", len); print len }') || true
    if [[ ! -t 2 || ! "$total" =~ ^[0-9]+$ ]] || (( total == 0 )); then
        curl -fL --retry 3 --connect-timeout 15 -C - --progress-bar -o "$out" "$url"
        return
    fi
    curl -fL --retry 3 --connect-timeout 15 -C - -sS -o "$out" "$url" &
    pid=$!
    prev=$(stat -c %s "$out" 2>/dev/null) || prev=0
    while kill -0 "$pid" 2>/dev/null; do
        sleep 1
        cur=$(stat -c %s "$out" 2>/dev/null) || cur=0
        delta=$(( cur - prev ))
        prev=$cur
        speed="$(human_size "$delta")B/s"
        eta="--:--"
        if (( cur >= total )); then
            eta="0:00"
        elif (( delta > 0 )); then
            eta_s=$(( (total - cur) / delta ))
            eta=$(printf '%d:%02d' $(( eta_s / 60 )) $(( eta_s % 60 )))
        fi
        draw_bar "$cur" "$total" "$speed" "$eta"
    done
    if ! wait "$pid"; then
        rc=$?
        printf '\n' >&2
        return "$rc"
    fi
    draw_bar "$total" "$total" "done" "0:00"
    printf '\n' >&2
}

# Run a command as root, using sudo only when we are not root already.
run_root() {
    if [[ ${EUID} -eq 0 ]]; then
        "$@"
    else
        sudo "$@"
    fi
}

require_deps() {
    local dep missing=()
    for dep in curl jq lsblk findmnt dd sha256sum sha512sum numfmt sort awk grep; do
        command -v "$dep" >/dev/null 2>&1 || missing+=("$dep")
    done
    ((${#missing[@]} == 0)) || die "missing required tools: ${missing[*]}"
    # The whole safety model depends on enumerating mountpoints. The
    # MOUNTPOINTS column needs util-linux >= 2.37; refuse to run without it
    # rather than silently seeing every disk as unmounted.
    lsblk -J -o MOUNTPOINTS >/dev/null 2>&1 \
        || die "lsblk lacks the MOUNTPOINTS column (util-linux >= 2.37 required)"
}

# Fetch a URL to stdout; used for HTML/checksum/JSON scraping.
fetch() {
    curl -fsSL --connect-timeout 15 --retry 3 "$1" \
        || return 1
}

# Fetch a URL to a file; used for binary data (signatures, keys).
fetch_to() {
    curl -fsSL --connect-timeout 15 --retry 3 -o "$1" "$2" \
        || return 1
}

# ---------------------------------------------------------------------------
# GPG signature verification
#
# Where a distro publishes signatures, the checksum data (or the ISO itself,
# depending on what the project signs) is verified against the project's
# signing key. Keys live in a private keyring under the cache dir — the
# user's own GnuPG setup is never touched. The trust anchor is the pinned
# fingerprint table below; each pin was cross-checked against the project's
# published verification documentation. A signature by any other key fails.
# ---------------------------------------------------------------------------

GNUPG_DIR="$CACHE_DIR/gnupg"

# Temp files created via mktempf are removed when the script exits.
TMP_FILES=()
trap '[[ ${#TMP_FILES[@]} -eq 0 ]] || rm -f -- "${TMP_FILES[@]}"' EXIT

# mktempf <varname> — create a temp file, register it for cleanup, and store
# its path in <varname> (no subshell, so the registration survives).
mktempf() {
    local t
    mkdir -p "$CACHE_DIR"
    t=$(mktemp "$CACHE_DIR/.tmp.XXXXXXXX")
    TMP_FILES+=("$t")
    printf -v "$1" '%s' "$t"
}

# Signature checking is possible and not disabled.
gpg_active() {
    (( ! OPT_NO_GPG )) && command -v gpg >/dev/null 2>&1
}

run_gpg() {
    mkdir -p "$GNUPG_DIR" && chmod 700 "$GNUPG_DIR"
    gpg --homedir "$GNUPG_DIR" --batch --no-tty "$@"
}

# Pinned signing-key fingerprints (primary keys). Documentation sources:
#   ubuntu       ubuntu.com/tutorials/how-to-verify-ubuntu (CD image key)
#   debian       debian.org/CD/verify
#   mint         linuxmint.com/verify.php
#   arch         archlinux.org/download/ ("PGP fingerprint")
#   opensuse     en.opensuse.org/openSUSE:Security_Features (project key)
#   alpine       key file served from alpinelinux.org itself
#   endeavouros  endeavouros.com/latest-release/ ("fingerprint")
#   kali         current archive key served from archive.kali.org
#                (rotated 2025; older docs list the pre-rotation key)
# fedora is absent on purpose: its release keys rotate, so the pin set is
# taken from the first-party bundle at fedoraproject.org/fedora.gpg per run.
declare -A DISTRO_GPG_FPR=(
    [ubuntu]="843938DF228D22F7B3742BC0D94AA3F0EFE21092"
    [debian]="DF9B9C49EAA9298432589D76DA87E80D6294BE9B"
    [mint]="27DEB15644C6B3CF3BD7D291300F846BA25BAE09"
    [arch]="3E80CA1A8B89F69CBA57D98A76A5EF9054449A5C"
    [opensuse]="AD485664E901B867051AB15F35A2F86E29B700A4"
    [alpine]="0482D84022F52DF1C4E7CD43293ACD0907D9495A"
    [endeavouros]="8F43FC374CD4CEEA19CEE323E3D8752ACDF595A1"
    [kali]="827C8569F2518CC677FECA1AED65462EC8D5E4C5"
)

# Where to obtain each key. The transport does not need to be trusted for
# the pinned distros — verification is against the fingerprint, not the URL.
GPG_KEYSERVER="https://keyserver.ubuntu.com/pks/lookup?op=get&search=0x"
declare -A DISTRO_GPG_KEYSRC=(
    [ubuntu]="${GPG_KEYSERVER}843938DF228D22F7B3742BC0D94AA3F0EFE21092"
    [debian]="${GPG_KEYSERVER}DF9B9C49EAA9298432589D76DA87E80D6294BE9B"
    [mint]="${GPG_KEYSERVER}27DEB15644C6B3CF3BD7D291300F846BA25BAE09"
    [arch]="${GPG_KEYSERVER}3E80CA1A8B89F69CBA57D98A76A5EF9054449A5C"
    [opensuse]="${GPG_KEYSERVER}AD485664E901B867051AB15F35A2F86E29B700A4"
    [alpine]="https://alpinelinux.org/keys/ncopa.asc"
    [endeavouros]="https://raw.githubusercontent.com/endeavouros-team/keyring/master/endeavouros.gpg"
    [fedora]="https://fedoraproject.org/fedora.gpg"
    [kali]="https://archive.kali.org/archive-key.asc"
)

GPG_DYNAMIC_FPRS=""   # pin set for distros without a static pin (fedora)

# Make sure the distro's signing key(s) are present in the private keyring.
gpg_ensure_keys() {
    local id="$1" fpr keyfile absent=0
    local pins="${DISTRO_GPG_FPR[$id]:-}"
    if [[ -n "$pins" ]]; then
        for fpr in $pins; do
            run_gpg --list-keys "$fpr" >/dev/null 2>&1 || absent=1
        done
        (( absent )) || return 0
    fi
    mktempf keyfile
    fetch_to "$keyfile" "${DISTRO_GPG_KEYSRC[$id]}" \
        || die "cannot download the $id signing key"
    if [[ -z "$pins" ]]; then
        # No static pin (rotating release keys): pin exactly the set of
        # fingerprints the first-party key bundle contains right now.
        GPG_DYNAMIC_FPRS=$(run_gpg --show-keys --with-colons "$keyfile" 2>/dev/null \
            | awk -F: '$1 == "fpr" {print $10}')
        [[ -n "$GPG_DYNAMIC_FPRS" ]] || die "no keys found in the $id key bundle"
    fi
    run_gpg --import "$keyfile" >/dev/null 2>&1 \
        || die "could not import the $id signing key"
    for fpr in $pins; do
        run_gpg --list-keys "$fpr" >/dev/null 2>&1 \
            || die "fetched $id key does not match the pinned fingerprint $fpr"
    done
}

# Verify a detached (sig + data) or clearsigned (sig only) signature and
# require the signer's primary key to be pinned for this distro.
gpg_verify_signed() {
    local id="$1" sig="$2" data="${3:-}" status signer fpr
    gpg_ensure_keys "$id"
    if [[ -n "$data" ]]; then
        status=$(run_gpg --status-fd 1 --verify "$sig" "$data" 2>/dev/null) || return 1
    else
        status=$(run_gpg --status-fd 1 --verify "$sig" 2>/dev/null) || return 1
    fi
    signer=$(awk '/^\[GNUPG:\] VALIDSIG/ {print $NF; exit}' <<<"$status")
    [[ -n "$signer" ]] || return 1
    for fpr in ${DISTRO_GPG_FPR[$id]:-$GPG_DYNAMIC_FPRS}; do
        [[ "$signer" == "$fpr" ]] && return 0
    done
    warn "signature made by unexpected key $signer"
    return 1
}

# Fetch a checksum file plus its detached signature, verify, and print the
# checksum contents. Proceeds unverified (with a loud warning) only when
# gpg is unavailable or --no-gpg was given.
fetch_signed_sums() {
    local id="$1" sums_url="$2" sig_url="$3" sums sig
    if ! gpg_active; then
        warn "GPG signature of the $id checksums NOT verified (gpg missing or --no-gpg)"
        fetch "$sums_url" || return 1
        return 0
    fi
    mktempf sums
    mktempf sig
    fetch_to "$sums" "$sums_url" || return 1
    fetch_to "$sig" "$sig_url" || die "cannot fetch the $id checksum signature"
    gpg_verify_signed "$id" "$sig" "$sums" \
        || die "GPG verification of the $id checksums FAILED — do not trust this source"
    info "Checksum signature verified ($id signing key)"
    cat "$sums"
}

# ---------------------------------------------------------------------------
# Distro registry
#
# Each distro has a description in DISTRO_DESC and a resolver function
# resolve_<id>() that must set these globals:
#   RESOLVED_URL      full download URL for the ISO
#   RESOLVED_FILE     filename used in the local cache
#   RESOLVED_HASH     expected hash (lowercase hex) from the official sums
#   RESOLVED_ALGO     hash algorithm: "sha256" (default), "sha512", or
#                     "none" for upstreams that publish no integrity data
#                     at all (download trust rests on TLS alone — warned
#                     loudly; the post-write read-back check still runs)
# Resolvers scrape the official "current/latest" locations so the tool never
# hardcodes version numbers.
# ---------------------------------------------------------------------------

DISTRO_IDS=(ubuntu debian fedora arch mint opensuse alpine popos endeavouros
            bazzite kali omarchy netbootxyz)

declare -A DISTRO_DESC=(
    [ubuntu]="Ubuntu Desktop, latest LTS (amd64)"
    [debian]="Debian stable netinst (amd64)"
    [fedora]="Fedora Workstation Live, latest release (x86_64)"
    [arch]="Arch Linux, latest monthly ISO (x86_64)"
    [mint]="Linux Mint Cinnamon, latest release (64-bit)"
    [opensuse]="openSUSE Tumbleweed DVD, current snapshot (x86_64)"
    [alpine]="Alpine Linux standard, latest stable (x86_64)"
    [popos]="Pop!_OS latest LTS, Intel/AMD graphics image (amd64)"
    [endeavouros]="EndeavourOS, latest release (x86_64)"
    [bazzite]="Bazzite KDE desktop (gaming-focused Fedora), stable (amd64)"
    [kali]="Kali Linux Live, latest release (amd64)"
    [omarchy]="Omarchy — opinionated Arch/Hyprland by DHH (amd64)"
    [netbootxyz]="netboot.xyz network installer (tiny, boots many distros)"
)

# RESOLVED_ALGO is sha256 unless a resolver overrides it (EndeavourOS
# publishes sha512 sums).
RESOLVED_URL="" RESOLVED_FILE="" RESOLVED_HASH="" RESOLVED_ALGO="sha256"

# Extract "<hash>  filename" style checksum for a given filename.
# Accepts the common variants: "hash filename", "hash *filename".
# CRLF line endings are stripped so a served \r cannot break the match.
checksum_for() {
    local sums="$1" file="$2"
    awk -v f="$file" '
        { sub(/\r$/, ""); fn = $2; sub(/^\*/, "", fn) }
        fn == f { print tolower($1); exit }
    ' <<<"$sums"
}

resolve_ubuntu() {
    local base="https://releases.ubuntu.com"
    local index versions ver sums
    index=$(fetch "$base/") || die "cannot reach $base"
    # Collect release directories like 24.04.2/ and keep LTS ones
    # (even major year, April release), newest last.
    versions=$(grep -oE 'href="[0-9]+\.[0-9]+(\.[0-9]+)?/"' <<<"$index" \
        | grep -oE '[0-9]+\.[0-9]+(\.[0-9]+)?' | sort -uV) || true
    ver=""
    local v major minor
    while IFS= read -r v; do
        major=${v%%.*}; minor=${v#*.}; minor=${minor%%.*}
        if (( major % 2 == 0 )) && [[ "$minor" == "04" ]]; then
            ver="$v"
        fi
    done <<<"$versions"
    [[ -n "$ver" ]] || die "could not determine latest Ubuntu LTS from $base"
    sums=$(fetch_signed_sums ubuntu "$base/$ver/SHA256SUMS" "$base/$ver/SHA256SUMS.gpg") \
        || die "cannot fetch Ubuntu SHA256SUMS"
    RESOLVED_FILE=$(awk '{ fn=$2; sub(/^\*/,"",fn) }
        fn ~ /^ubuntu-.*-desktop-amd64\.iso$/ { print fn; exit }' <<<"$sums")
    [[ -n "$RESOLVED_FILE" ]] || die "no desktop ISO found in Ubuntu $ver checksums"
    RESOLVED_URL="$base/$ver/$RESOLVED_FILE"
    RESOLVED_HASH=$(checksum_for "$sums" "$RESOLVED_FILE")
}

resolve_debian() {
    local base="https://cdimage.debian.org/debian-cd/current/amd64/iso-cd"
    local sums
    sums=$(fetch_signed_sums debian "$base/SHA256SUMS" "$base/SHA256SUMS.sign") \
        || die "cannot fetch Debian SHA256SUMS"
    RESOLVED_FILE=$(awk '{ fn=$2; sub(/^\*/,"",fn) }
        fn ~ /^debian-[0-9.]+-amd64-netinst\.iso$/ { print fn; exit }' <<<"$sums")
    [[ -n "$RESOLVED_FILE" ]] || die "no netinst ISO found in Debian checksums"
    RESOLVED_URL="$base/$RESOLVED_FILE"
    RESOLVED_HASH=$(checksum_for "$sums" "$RESOLVED_FILE")
}

resolve_fedora() {
    # Fedora publishes machine-readable release data (used by Media Writer).
    local json
    json=$(fetch "https://fedoraproject.org/releases.json") \
        || die "cannot fetch Fedora releases.json"
    read -r RESOLVED_URL RESOLVED_HASH < <(jq -r '
        [ .[]
          | select(.variant == "Workstation" and .arch == "x86_64")
          | select(.link | endswith(".iso"))
          | select(.version | test("^[0-9]+$")) ]
        | max_by(.version | tonumber)
        | "\(.link) \(.sha256)"' <<<"$json") || true
    [[ -n "${RESOLVED_URL:-}" && "$RESOLVED_URL" != "null" ]] \
        || die "could not find a Fedora Workstation ISO in releases.json"
    RESOLVED_FILE="${RESOLVED_URL##*/}"
    RESOLVED_HASH="${RESOLVED_HASH,,}"

    # Fedora's CHECKSUM files are clearsigned; verify one against the
    # first-party key bundle and require agreement with releases.json.
    if gpg_active; then
        local relver dir checksum_url cfile signed_hash
        [[ "$RESOLVED_FILE" =~ -([0-9]+-[0-9.]+)\.x86_64\.iso$ ]] \
            || die "unexpected Fedora ISO name '$RESOLVED_FILE'"
        relver="${BASH_REMATCH[1]}"
        # dl.fedoraproject.org is first-party (no mirror redirect).
        dir="${RESOLVED_URL%/*}"
        checksum_url="${dir/download.fedoraproject.org/dl.fedoraproject.org}/Fedora-Workstation-${relver}-x86_64-CHECKSUM"
        mktempf cfile
        fetch_to "$cfile" "$checksum_url" || die "cannot fetch the Fedora CHECKSUM file"
        gpg_verify_signed fedora "$cfile" \
            || die "GPG verification of the Fedora CHECKSUM FAILED — do not trust this source"
        signed_hash=$(awk -v f="$RESOLVED_FILE" \
            '$1 == "SHA256" && $2 == "(" f ")" { print tolower($4); exit }' "$cfile")
        [[ -n "$signed_hash" ]] || die "no entry for $RESOLVED_FILE in the Fedora CHECKSUM file"
        [[ "$signed_hash" == "$RESOLVED_HASH" ]] \
            || die "Fedora releases.json and the signed CHECKSUM disagree — refusing"
        info "Checksum signature verified (fedora signing key)"
    else
        warn "GPG signature of the fedora checksums NOT verified (gpg missing or --no-gpg)"
    fi
}

resolve_arch() {
    local base="https://geo.mirror.pkgbuild.com/iso/latest"
    local sums
    sums=$(fetch "$base/sha256sums.txt") || die "cannot fetch Arch sha256sums.txt"
    RESOLVED_FILE=$(awk '{ fn=$2; sub(/^\*/,"",fn) }
        fn ~ /^archlinux-[0-9]{4}\.[0-9]{2}\.[0-9]{2}-x86_64\.iso$/ { print fn; exit }' \
        <<<"$sums")
    [[ -n "$RESOLVED_FILE" ]] || die "no dated ISO found in Arch checksums"
    RESOLVED_URL="$base/$RESOLVED_FILE"
    RESOLVED_HASH=$(checksum_for "$sums" "$RESOLVED_FILE")
    # Arch signs the ISO itself, not the checksum file.
    RESOLVED_ISO_SIG_URL="$RESOLVED_URL.sig"
}

resolve_mint() {
    local base="https://mirrors.edge.kernel.org/linuxmint/stable"
    local index ver sums
    index=$(fetch "$base/") || die "cannot reach $base"
    ver=$(grep -oE 'href="[0-9]+(\.[0-9]+)*/"' <<<"$index" \
        | grep -oE '[0-9]+(\.[0-9]+)*' | sort -uV | tail -1)
    [[ -n "$ver" ]] || die "could not determine latest Mint version"
    sums=$(fetch_signed_sums mint "$base/$ver/sha256sum.txt" "$base/$ver/sha256sum.txt.gpg") \
        || die "cannot fetch Mint sha256sum.txt"
    RESOLVED_FILE="linuxmint-${ver}-cinnamon-64bit.iso"
    RESOLVED_URL="$base/$ver/$RESOLVED_FILE"
    RESOLVED_HASH=$(checksum_for "$sums" "$RESOLVED_FILE")
}

resolve_opensuse() {
    # Tumbleweed publishes a stable "Current" name with an adjacent .sha256,
    # itself signed by the openSUSE project key (.sha256.asc).
    local base="https://download.opensuse.org/tumbleweed/iso" sums
    RESOLVED_FILE="openSUSE-Tumbleweed-DVD-x86_64-Current.iso"
    RESOLVED_URL="$base/$RESOLVED_FILE"
    sums=$(fetch_signed_sums opensuse "$base/$RESOLVED_FILE.sha256" "$base/$RESOLVED_FILE.sha256.asc") \
        || die "cannot fetch openSUSE checksum"
    RESOLVED_HASH=$(awk '{print tolower($1); exit}' <<<"$sums")
}

resolve_alpine() {
    local base="https://dl-cdn.alpinelinux.org/alpine/latest-stable/releases/x86_64"
    local yaml
    yaml=$(fetch "$base/latest-releases.yaml") || die "cannot fetch Alpine release list"
    # Parse the YAML block for the "alpine-standard" flavor.
    read -r RESOLVED_FILE RESOLVED_HASH < <(awk '
        /flavor:/  { flavor = $2 }
        /file:/    { file = $2 }
        /sha256:/  { if (flavor == "alpine-standard" && file != "") {
                         print file, tolower($2); exit } }' <<<"$yaml") || true
    [[ -n "${RESOLVED_FILE:-}" ]] || die "no alpine-standard entry in release list"
    RESOLVED_URL="$base/$RESOLVED_FILE"
    # Alpine signs the ISO itself (detached .asc).
    RESOLVED_ISO_SIG_URL="$RESOLVED_URL.asc"
}

resolve_popos() {
    # System76 publishes a JSON build API per release/channel, but no
    # "latest" endpoint — probe plausible LTS versions, newest first.
    local year y ver json
    year=$(date +%Y)
    for (( y = year + 2 - year % 2; y >= 2020; y -= 2 )); do
        ver="$(( y - 2000 )).04"
        # 404s are expected while probing not-yet-released versions.
        json=$(fetch "https://api.pop-os.org/builds/$ver/intel" 2>/dev/null) || continue
        read -r RESOLVED_URL RESOLVED_HASH < <(jq -r '"\(.url) \(.sha_sum)"' <<<"$json") || true
        [[ -n "${RESOLVED_URL:-}" && "$RESOLVED_URL" != "null" ]] || continue
        RESOLVED_FILE="${RESOLVED_URL##*/}"
        RESOLVED_HASH="${RESOLVED_HASH,,}"
        return 0
    done
    die "could not find a Pop!_OS build via api.pop-os.org"
}

resolve_endeavouros() {
    # Trust anchor: endeavouros.com (first-party) supplies both the current
    # ISO filename and its sha512. Community mirrors only supply the bytes,
    # so a compromised mirror cannot serve a self-consistent malicious pair.
    local page hashes mirror
    page=$(fetch "https://endeavouros.com/latest-release/") \
        || page=$(fetch "https://endeavouros.com/") \
        || die "cannot reach endeavouros.com"
    # Filenames embed a codename and a date (EndeavourOS_Name-YYYY.MM.DD.iso);
    # pick the newest by the date part.
    RESOLVED_FILE=$(grep -oE 'EndeavourOS_[A-Za-z0-9_-]+-[0-9]{4}\.[0-9]{2}\.[0-9]{2}\.iso' <<<"$page" \
        | sort -u \
        | awk '{ d = $0; sub(/\.iso$/, "", d); n = split(d, a, "-"); print a[n], $0 }' \
        | sort -k1,1 | tail -1 | awk '{print $2}')
    [[ -n "$RESOLVED_FILE" ]] || die "no EndeavourOS ISO referenced on endeavouros.com"
    hashes=$(grep -oE '[0-9a-f]{128}' <<<"$page" | sort -u)
    [[ -n "$hashes" && $(wc -l <<<"$hashes") -eq 1 ]] \
        || die "could not identify a unique sha512 on endeavouros.com"
    RESOLVED_HASH="$hashes"
    RESOLVED_ALGO="sha512"
    # A mismatched (stale) mirror copy fails checksum verification, so any
    # healthy mirror is acceptable as a byte source.
    for mirror in "https://mirror.alpix.eu/endeavouros/iso" \
                  "https://mirror.moson.org/endeavouros/iso"; do
        if curl -fsIL --connect-timeout 15 -o /dev/null "$mirror/$RESOLVED_FILE"; then
            RESOLVED_URL="$mirror/$RESOLVED_FILE"
            # The .sig is detached over the ISO; the mirror serving it is
            # irrelevant because the signer key is pinned first-party.
            RESOLVED_ISO_SIG_URL="$RESOLVED_URL.sig"
            return 0
        fi
    done
    die "no EndeavourOS mirror currently serves $RESOLVED_FILE"
}

resolve_bazzite() {
    # Stable alias for the KDE desktop image, with an adjacent checksum file.
    local base="https://download.bazzite.gg" sums
    RESOLVED_FILE="bazzite-stable-amd64.iso"
    RESOLVED_URL="$base/$RESOLVED_FILE"
    sums=$(fetch "$base/$RESOLVED_FILE-CHECKSUM") || die "cannot fetch Bazzite checksum"
    RESOLVED_HASH=$(checksum_for "$sums" "$RESOLVED_FILE")
}

resolve_kali() {
    local base="https://cdimage.kali.org/current"
    local sums
    sums=$(fetch_signed_sums kali "$base/SHA256SUMS" "$base/SHA256SUMS.gpg") \
        || die "cannot fetch Kali SHA256SUMS"
    RESOLVED_FILE=$(awk '{ fn=$2; sub(/^\*/,"",fn) }
        fn ~ /^kali-linux-[0-9]{4}\.[0-9a-z]+-live-amd64\.iso$/ { print fn; exit }' <<<"$sums")
    [[ -n "$RESOLVED_FILE" ]] || die "no live ISO found in Kali checksums"
    RESOLVED_URL="$base/$RESOLVED_FILE"
    RESOLVED_HASH=$(checksum_for "$sums" "$RESOLVED_FILE")
}

resolve_omarchy() {
    # Omarchy publishes neither checksums nor signatures — only the ISO
    # itself over TLS. The homepage carries the current version's URL.
    local page
    page=$(fetch "https://omarchy.org") || die "cannot reach omarchy.org"
    RESOLVED_URL=$(grep -oE 'https://iso\.omarchy\.org/omarchy-[0-9]+\.[0-9]+\.[0-9]+\.iso' \
        <<<"$page" | head -1)
    [[ -n "$RESOLVED_URL" ]] || die "no ISO link found on omarchy.org"
    RESOLVED_FILE="${RESOLVED_URL##*/}"
    RESOLVED_ALGO="none"
}

resolve_netbootxyz() {
    local base="https://boot.netboot.xyz/ipxe"
    local sums
    RESOLVED_FILE="netboot.xyz.iso"
    RESOLVED_URL="$base/$RESOLVED_FILE"
    sums=$(fetch "$base/netboot.xyz-sha256-checksums.txt") \
        || die "cannot fetch netboot.xyz checksums"
    RESOLVED_HASH=$(awk '/netboot\.xyz\.iso$/ {print tolower($1); exit}' <<<"$sums")
}

resolve_distro() {
    local id="$1"
    declare -F "resolve_$id" >/dev/null || die "unknown distro '$id' (see: $SCRIPT_NAME distros)"
    RESOLVED_URL="" RESOLVED_FILE="" RESOLVED_HASH="" RESOLVED_ALGO="sha256"
    RESOLVED_ISO_SIG_URL="" RESOLVED_GPG_ID="$id"
    info "Resolving latest release for '$id'..."
    "resolve_$id"
    if [[ "$RESOLVED_ALGO" == "none" ]]; then
        warn "$id publishes no checksums or signatures — download integrity rests on TLS alone"
        return 0
    fi
    local want=64
    [[ "$RESOLVED_ALGO" == "sha512" ]] && want=128
    [[ "$RESOLVED_HASH" =~ ^[0-9a-f]+$ && ${#RESOLVED_HASH} -eq $want ]] \
        || die "resolver for '$id' returned an invalid $RESOLVED_ALGO ('$RESOLVED_HASH')"
}

# ---------------------------------------------------------------------------
# Device handling
# ---------------------------------------------------------------------------

# List whole disks that look like USB sticks: TYPE=disk and (removable or
# USB transport). Prints tab-separated: path, bytes, model, transport.
list_usb_devices() {
    lsblk -J -b -o PATH,TYPE,RM,TRAN,SIZE,MODEL 2>/dev/null | jq -r '
        .blockdevices[]
        | select(.type == "disk")
        | select((.rm == true or .rm == "1" or .rm == 1) or .tran == "usb")
        | [.path, (.size|tostring), (.model // "-" | tostring), (.tran // "-")]
        | @tsv'
}

# Print every mountpoint found on the device or any of its descendants
# (partitions, LUKS mappings, LVM volumes...). One per line.
# Returns non-zero (with no output) when the mount table cannot be read —
# callers MUST treat that as fatal, never as "no mounts".
device_mounts() {
    local json
    json=$(lsblk -J -o MOUNTPOINTS --paths "$1") || return 1
    jq -r '
        [.blockdevices[] | recurse(.children[]?) | .mountpoints[]?]
        | map(select(. != null)) | .[]' <<<"$json"
}

# A mountpoint that makes a disk part of the running system. Writing to such
# a disk is refused unconditionally — --force does not override this.
is_critical_mount() {
    case "$1" in
        /|/boot|/boot/*|/efi|/efi/*|/home|/home/*|/usr|/usr/*|/var|/var/*|\
        /etc|/etc/*|/opt|/opt/*|/srv|/srv/*|/root|/root/*|/tmp|/tmp/*|\
        /nix|/nix/*|"[SWAP]") return 0 ;;
        *) return 1 ;;
    esac
}

# ZFS pool member disks carry no mountpoint that lsblk can see, so an
# imported pool's disks would otherwise look idle. Refuse them outright;
# --force does not override this either.
refuse_zfs_pool_member() {
    local dev="$1" member
    command -v zpool >/dev/null 2>&1 || return 0
    while IFS= read -r member; do
        [[ -n "$member" ]] || continue
        if [[ "$member" == "$dev" || "$member" =~ ^"$dev"p?[0-9]+$ ]]; then
            die "'$dev' is a member of an imported ZFS pool. Refusing."
        fi
    done < <(zpool list -vHLP 2>/dev/null | awk '$1 ~ /^\/dev\// {print $1}')
    return 0
}

# Validate the target device and unmount its partitions. Dies on anything
# that looks like a system disk.
prepare_device() {
    local dev="$1" mp mounts
    [[ -e "$dev" ]] || die "device '$dev' does not exist"
    [[ -b "$dev" ]] || die "'$dev' is not a block device"

    local dtype rm tran
    read -r dtype rm tran < <(lsblk -dno TYPE,RM,TRAN "$dev" | awk '{print $1, $2, ($3 == "" ? "-" : $3)}')
    [[ "$dtype" == "disk" ]] \
        || die "'$dev' is a $dtype — pass the whole disk (e.g. /dev/sdb, not /dev/sdb1)"

    # If the mount table cannot be read we must not write anywhere.
    mounts=$(device_mounts "$dev") \
        || die "cannot enumerate mountpoints on '$dev' (lsblk failed) — refusing to write"

    # Refuse anything hosting the running system, always.
    if [[ -n "$mounts" ]]; then
        while IFS= read -r mp; do
            if is_critical_mount "$mp"; then
                die "'$dev' hosts '$mp' — this looks like a system disk. Refusing."
            fi
        done <<<"$mounts"
    fi
    refuse_zfs_pool_member "$dev"

    # Require a removable/USB disk unless the user forces it.
    if [[ "$rm" != "1" && "$tran" != "usb" ]] && (( ! OPT_FORCE )); then
        die "'$dev' is not removable and not on the USB bus (use --force to override)"
    fi

    # Unmount anything (auto-)mounted from the stick itself.
    if [[ -n "$mounts" ]]; then
        while IFS= read -r mp; do
            info "Unmounting $mp"
            run_root umount "$mp" || die "could not unmount $mp"
        done <<<"$mounts"
    fi
}

device_summary() {
    lsblk -dno PATH,SIZE,MODEL,TRAN,SERIAL "$1" 2>/dev/null | sed 's/  */  /g'
}

# ---------------------------------------------------------------------------
# Download & checksum
# ---------------------------------------------------------------------------

# Verify a file against an expected hash; algo is "sha256" or "sha512".
# algo "none" means the upstream publishes nothing to verify against.
verify_hash() {
    local file="$1" expected="${2,,}" algo="${3:-sha256}" actual
    if [[ "$algo" == "none" ]]; then
        warn "no upstream checksum exists for $(basename "$file") — integrity check skipped"
        return 0
    fi
    info "Verifying ${algo^^} of $(basename "$file")..."
    actual=$("${algo}sum" "$file" | awk '{print tolower($1)}')
    [[ "$actual" == "$expected" ]]
}

# Download RESOLVED_URL into the cache, verify against RESOLVED_HASH and
# print the final path on stdout. Reuses a cached copy when the hash matches.
download_iso() {
    local target="$CACHE_DIR/$RESOLVED_FILE" part rc=0
    mkdir -p "$CACHE_DIR"

    if [[ -f "$target" ]]; then
        if verify_hash "$target" "$RESOLVED_HASH" "$RESOLVED_ALGO"; then
            verify_iso_signature "$target"
            ok "Using cached ISO: $target"
            printf '%s\n' "$target"
            return 0
        fi
        warn "cached copy has a stale/bad checksum — downloading again"
        rm -f -- "$target"
    fi

    part="$target.part"
    info "Downloading $RESOLVED_URL"
    download_with_bar "$RESOLVED_URL" "$part" || rc=$?
    # curl exit 33 = server rejected the resume range; the .part file is most
    # likely already complete, so fall through to the checksum.
    if (( rc != 0 && rc != 33 )); then
        die "download failed (curl exit $rc); partial file kept for resume: $part"
    fi
    mv -- "$part" "$target"

    verify_hash "$target" "$RESOLVED_HASH" "$RESOLVED_ALGO" \
        || { rm -f -- "$target"; die "checksum mismatch — deleted corrupt download, please retry"; }
    [[ "$RESOLVED_ALGO" == "none" ]] || ok "Checksum verified ($RESOLVED_HASH)"
    verify_iso_signature "$target"
    printf '%s\n' "$target"
}

# Verify the distro's detached signature over the downloaded ISO, when one
# is published (arch, alpine, endeavouros). No-op for the others.
verify_iso_signature() {
    local target="$1" sig
    [[ -n "$RESOLVED_ISO_SIG_URL" ]] || return 0
    if ! gpg_active; then
        warn "GPG signature of the ISO NOT verified (gpg missing or --no-gpg)"
        return 0
    fi
    mktempf sig
    fetch_to "$sig" "$RESOLVED_ISO_SIG_URL" || die "cannot fetch the ISO signature"
    info "Verifying ISO signature..."
    gpg_verify_signed "$RESOLVED_GPG_ID" "$sig" "$target" \
        || die "GPG verification of the ISO FAILED — do not trust this image"
    ok "ISO signature verified ($RESOLVED_GPG_ID signing key)"
}

# Quick sanity check: ISO9660 images carry "CD001" at offset 32769.
looks_like_iso() {
    [[ "$(dd if="$1" bs=1 skip=32769 count=5 2>/dev/null)" == "CD001" ]]
}

# ---------------------------------------------------------------------------
# Writing
# ---------------------------------------------------------------------------

confirm_write() {
    local dev="$1" iso="$2"
    printf '\n' >&2
    warn "ALL DATA ON THE FOLLOWING DEVICE WILL BE DESTROYED:"
    printf '    %s\n' "$(device_summary "$dev")" >&2
    printf '    image: %s (%s)\n\n' "$(basename "$iso")" \
        "$(human_size "$(stat -c %s "$iso")")" >&2

    (( OPT_YES )) && return 0
    local expected reply
    expected="$(basename "$dev")"
    read -r -p "Type the device name '$expected' to continue (anything else aborts): " reply \
        || die "aborted — no data was written"
    [[ "$reply" == "$expected" ]] || die "aborted — no data was written"
}

write_iso() {
    local iso="$1" dev="$2" iso_size
    iso_size=$(stat -c %s "$iso")

    # The device must be at least as large as the image.
    local dev_size
    dev_size=$(lsblk -dbno SIZE "$dev")
    (( dev_size >= iso_size )) \
        || die "device is too small: $(human_size "$dev_size") < $(human_size "$iso_size")"

    if ! looks_like_iso "$iso"; then
        warn "'$(basename "$iso")' does not look like an ISO9660 image"
        if (( ! OPT_YES )); then
            local reply
            read -r -p "Write it anyway? [y/N] " reply || die "aborted"
            [[ "$reply" =~ ^[Yy] ]] || die "aborted"
        fi
    fi

    confirm_write "$dev" "$iso"

    # Take the sudo password prompt up front so it does not collide with
    # (or invisibly stall behind) the progress display.
    run_root true || die "cannot gain root privileges"

    info "Writing $(human_size "$iso_size") to $dev (this can take a while)..."
    run_root dd if="$iso" of="$dev" bs=4M conv=fsync oflag=direct status=progress \
        2> >(dd_progress_bar "$iso_size") \
        || die "dd failed — the device may be in an inconsistent state"
    # Give the bar a moment to print its final newline (bash does not let
    # us wait on the process substitution directly).
    sleep 0.2
    sync
    ok "Image written."

    if (( ! OPT_NO_VERIFY )); then
        info "Verifying written data (reading $(human_size "$iso_size") back)..."
        local expected actual
        expected=$(sha256sum "$iso" | awk '{print tolower($1)}')
        # iflag=direct bypasses the page cache so we test the real device.
        # dd's stderr feeds the progress bar; real errors pass through it.
        actual=$(run_root dd if="$dev" bs=4M iflag=direct,count_bytes count="$iso_size" \
                    status=progress 2> >(dd_progress_bar "$iso_size") \
                    | sha256sum | awk '{print tolower($1)}') \
            || die "could not read the device back for verification"
        [[ "$actual" == "$expected" ]] \
            || die "read-back verification FAILED — do not trust this stick"
        ok "Read-back verification passed."
    fi

    run_root eject "$dev" 2>/dev/null || true
    ok "Done. You can remove the USB stick."
}

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

cmd_list() {
    local rows
    rows=$(list_usb_devices)
    if [[ -z "$rows" ]]; then
        info "No removable/USB disks found. Plug in a stick and try again."
        return 0
    fi
    {
        printf 'DEVICE\tSIZE\tMODEL\tBUS\n'
        while IFS=$'\t' read -r path size model tran; do
            printf '%s\t%s\t%s\t%s\n' "$path" "$(human_size "$size")" "$model" "$tran"
        done <<<"$rows"
    } | if command -v column >/dev/null 2>&1; then column -t -s $'\t'; else cat; fi
}

cmd_distros() {
    local id
    printf 'Available distros:\n'
    for id in "${DISTRO_IDS[@]}"; do
        printf '  %-12s %s\n' "$id" "${DISTRO_DESC[$id]}"
    done
    printf '\nUse a local image instead with: %s write --iso file.iso\n' "$SCRIPT_NAME"
}

cmd_info() {
    [[ -n "$OPT_DISTRO" ]] || die "usage: $SCRIPT_NAME info <distro>"
    resolve_distro "$OPT_DISTRO"
    printf 'distro:   %s\n' "$OPT_DISTRO"
    printf 'file:     %s\n' "$RESOLVED_FILE"
    printf 'url:      %s\n' "$RESOLVED_URL"
    if [[ "$RESOLVED_ALGO" == "none" ]]; then
        printf 'checksum: NONE published by upstream (TLS-only download)\n'
    else
        printf '%-9s %s\n' "$RESOLVED_ALGO:" "$RESOLVED_HASH"
    fi
    local gpgline="no signatures published (checksum + TLS only)"
    [[ "$RESOLVED_ALGO" == "none" ]] && gpgline="none — upstream publishes no integrity data at all"
    if [[ -n "$RESOLVED_ISO_SIG_URL" ]]; then
        gpgline="detached ISO signature, key ${DISTRO_GPG_FPR[$OPT_DISTRO]:-}"
    elif [[ -n "${DISTRO_GPG_FPR[$OPT_DISTRO]:-}" ]]; then
        gpgline="signed checksums, key ${DISTRO_GPG_FPR[$OPT_DISTRO]}"
    elif [[ "$OPT_DISTRO" == "fedora" ]]; then
        gpgline="signed checksums, keys from fedoraproject.org/fedora.gpg"
    fi
    printf 'gpg:      %s\n' "$gpgline"
}

cmd_download() {
    [[ -n "$OPT_DISTRO" ]] || die "usage: $SCRIPT_NAME download <distro>"
    resolve_distro "$OPT_DISTRO"
    download_iso >/dev/null
}

cmd_write() {
    local iso
    if [[ -n "$OPT_DISTRO" && -n "$OPT_ISO" ]]; then
        die "--distro and --iso are mutually exclusive"
    elif [[ -n "$OPT_DISTRO" ]]; then
        resolve_distro "$OPT_DISTRO"
        iso=$(download_iso)
    elif [[ -n "$OPT_ISO" ]]; then
        iso="$OPT_ISO"
        [[ -f "$iso" ]] || die "ISO not found: $iso"
    else
        die "specify an image: --distro <name> or --iso <file>"
    fi

    if [[ -z "$OPT_DEVICE" ]]; then
        if (( OPT_YES )); then
            die "--yes requires an explicit --device"
        fi
        OPT_DEVICE=$(pick_device)
    fi

    prepare_device "$OPT_DEVICE"
    write_iso "$iso" "$OPT_DEVICE"
}

# Interactive device picker; prints the chosen path on stdout.
pick_device() {
    local rows paths=() labels=() i
    rows=$(list_usb_devices)
    [[ -n "$rows" ]] || die "no removable/USB disks found — plug one in and retry"
    while IFS=$'\t' read -r path size model tran; do
        paths+=("$path")
        labels+=("$path  $(human_size "$size")  $model ($tran)")
    done <<<"$rows"

    printf '\nSelect the target device:\n' >&2
    local sel
    select sel in "${labels[@]}"; do
        [[ -n "$sel" ]] || { warn "invalid choice"; continue; }
        i=$((REPLY - 1))
        printf '%s\n' "${paths[$i]}"
        return 0
    done </dev/tty
    die "no device selected"
}

# Interactive wizard: pick a source, pick a device, write.
cmd_interactive() {
    [[ -t 0 ]] || die "no terminal available — use explicit commands (see --help)"
    printf '%s v%s — write a Linux installer to a USB stick\n\n' "$SCRIPT_NAME" "$VERSION"

    local choices=() id
    for id in "${DISTRO_IDS[@]}"; do
        choices+=("$id — ${DISTRO_DESC[$id]}")
    done
    choices+=("local ISO file...")

    printf 'What do you want to write?\n'
    local sel
    select sel in "${choices[@]}"; do
        [[ -n "$sel" ]] || { warn "invalid choice"; continue; }
        break
    done </dev/tty
    [[ -n "${sel:-}" ]] || die "nothing selected"

    if [[ "$sel" == "local ISO file..." ]]; then
        read -e -r -p "Path to ISO: " OPT_ISO </dev/tty || die "aborted"
        [[ -n "$OPT_ISO" ]] || die "no path entered"
        # Expand a leading ~/ only; '~user/...' is passed through untouched.
        # shellcheck disable=SC2088  # comparing against a literal tilde is the point
        [[ "$OPT_ISO" == "~/"* ]] && OPT_ISO="$HOME/${OPT_ISO#\~/}"
    else
        OPT_DISTRO="${sel%% *}"
    fi

    # Ask both questions up front — the (possibly long) download starts only
    # after the target device is chosen.
    OPT_DEVICE=$(pick_device)
    cmd_write
}

usage() {
    cat <<EOF
$SCRIPT_NAME v$VERSION — create bootable USB installers for Linux distros.

USAGE
    $SCRIPT_NAME                          interactive wizard
    $SCRIPT_NAME list                     list candidate USB devices
    $SCRIPT_NAME distros                  list supported distros
    $SCRIPT_NAME info <distro>            show resolved URL and checksum
    $SCRIPT_NAME download <distro>        download + verify ISO into the cache
    $SCRIPT_NAME write [options]          write an image to a USB device

WRITE OPTIONS
    --distro <name>     download (or reuse cached) ISO for <name>
    --iso <file>        use a local image file instead
    --device <dev>      target whole-disk device, e.g. /dev/sdb
    --yes               no confirmation prompt (requires --device)
    --force             allow non-removable disks (system disks stay blocked)
    --no-verify         skip post-write read-back verification
    --no-gpg            skip GPG signature verification (checksums still checked)

OTHER
    -h, --help          this help
    -V, --version       print version

EXAMPLES
    $SCRIPT_NAME write --distro fedora --device /dev/sdb
    $SCRIPT_NAME write --iso ~/isos/custom.iso --device /dev/sdb --yes
    ISO cache: $CACHE_DIR
EOF
}

# ---------------------------------------------------------------------------
# Argument parsing / main
# ---------------------------------------------------------------------------

parse_args() {
    COMMAND=""
    while (($#)); do
        case "$1" in
            list|distros|write) COMMAND="$1" ;;
            info|download)
                COMMAND="$1"
                if [[ -n "${2:-}" && "${2:0:1}" != "-" ]]; then
                    OPT_DISTRO="$2"; shift
                fi
                ;;
            --distro)    OPT_DISTRO="${2:?--distro needs a value}"; shift ;;
            --iso)       OPT_ISO="${2:?--iso needs a value}"; shift ;;
            --device)    OPT_DEVICE="${2:?--device needs a value}"; shift ;;
            --yes|-y)    OPT_YES=1 ;;
            --force)     OPT_FORCE=1 ;;
            --no-verify) OPT_NO_VERIFY=1 ;;
            --no-gpg)    OPT_NO_GPG=1 ;;
            -h|--help)   usage; exit 0 ;;
            -V|--version) printf '%s\n' "$VERSION"; exit 0 ;;
            *) die "unknown argument '$1' (see --help)" ;;
        esac
        shift
    done
}

main() {
    require_deps
    parse_args "$@"
    # Options without a command must not fall into the wizard: pre-set
    # --device/--yes there could trigger a write with no confirmation.
    if [[ -z "${COMMAND:-}" ]] \
        && [[ -n "$OPT_DISTRO$OPT_ISO$OPT_DEVICE" || $((OPT_YES + OPT_FORCE + OPT_NO_VERIFY)) -gt 0 ]]; then
        die "options need a command — did you mean: $SCRIPT_NAME write ...? (see --help)"
    fi
    case "${COMMAND:-}" in
        list)     cmd_list ;;
        distros)  cmd_distros ;;
        info)     cmd_info ;;
        download) cmd_download ;;
        write)    cmd_write ;;
        "")       cmd_interactive ;;
    esac
}

# Run only when executed, not when sourced (sourcing is used by tests).
if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
    main "$@"
fi
